.empty {
  border: 1rpx dashed var(--wr-border, #cbd5e1);
  border-radius: 24rpx;
  background: var(--wr-surface, #ffffff);
  padding: 42rpx 28rpx;
  text-align: center;
}

.title {
  color: var(--wr-text, #0f1923);
  font-size: 30rpx;
  font-weight: 800;
}

.description {
  margin-top: 12rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 26rpx;
  line-height: 1.5;
}
