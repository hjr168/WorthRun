.checklist {
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-surface, #ffffff);
}

.check-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 92rpx;
  border-bottom: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  padding: 18rpx 22rpx;
}

.check-icon {
  flex: 0 0 36rpx;
  width: 36rpx;
  height: 36rpx;
  margin-top: 3rpx;
}

.item-copy {
  flex: 1;
  min-width: 0;
}

.check-row:last-child {
  border-bottom: 0;
}

.item-name {
  color: var(--wr-text, #0f1923);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
  overflow-wrap: break-word;
  word-break: normal;
}

.group-name {
  margin-top: 6rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 24rpx;
}

.status {
  flex-shrink: 0;
  border-radius: 999rpx;
  background: var(--wr-surface-soft, #eef0f3);
  color: var(--wr-muted, #6b7a8d);
  padding: 6rpx 14rpx;
  font-size: 24rpx;
  line-height: 1.35;
}
