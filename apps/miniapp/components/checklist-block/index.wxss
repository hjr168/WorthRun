.checklist {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #ffffff;
}

.check-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 92rpx;
  border-bottom: 1rpx solid #e2e8f0;
  padding: 18rpx 22rpx;
}

.check-row:last-child {
  border-bottom: 0;
}

.item-name {
  color: #111827;
  font-size: 28rpx;
}

.group-name {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.status {
  flex-shrink: 0;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #64748b;
  padding: 6rpx 14rpx;
  font-size: 24rpx;
}
