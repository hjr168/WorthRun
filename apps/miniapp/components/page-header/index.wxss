.page-header {
  width: 100%;
  overflow: hidden;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #122b32 0%, #1c4650 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(18, 43, 50, 0.12);
}

.page-header.compact {
  padding: 24rpx 28rpx;
}

.page-header.hero {
  padding: 30rpx 32rpx;
}

.page-header-kicker {
  margin-bottom: 6rpx;
  color: #8bd8ce;
  font-size: 23rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  line-height: 1.3;
}

.page-header-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero .page-header-title {
  font-size: 40rpx;
}

.page-header-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
  line-height: 1.55;
}
