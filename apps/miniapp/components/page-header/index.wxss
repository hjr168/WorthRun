.page-header {
  position: relative;
  width: 100%;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-hero, #ffffff);
  color: var(--wr-hero-text, #0f1923);
  box-shadow: var(--wr-shadow, 0 8rpx 24rpx rgba(15, 25, 35, 0.05));
}

.page-header-accent {
  width: var(--wr-banner-accent-width, 100%);
  height: var(--wr-banner-accent-height, 12rpx);
  margin: var(--wr-banner-accent-margin, 0);
  border-radius: var(--wr-banner-accent-radius, 0);
  background: var(--wr-primary, #ff5c1a);
}

.page-header-body {
  padding: var(--wr-banner-body-padding, 34rpx 40rpx 38rpx);
}

.page-header.plain {
  overflow: visible;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.page-header.plain .page-header-accent {
  display: none;
}

.page-header.plain .page-header-body {
  padding: 0;
}

.page-header-kicker {
  margin-bottom: 6rpx;
  color: var(--wr-primary, #ff5c1a);
  font-size: 23rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  line-height: 1.3;
}

.page-header-title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
}

.plain .page-header-title {
  font-size: 52rpx;
}

.page-header-subtitle {
  margin-top: 8rpx;
  color: var(--wr-hero-muted, #6b7a8d);
  font-size: 25rpx;
  line-height: 1.55;
}
