.event-card {
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-surface, #ffffff);
  padding: 32rpx;
  box-shadow: 0 3rpx 8rpx rgba(15, 25, 35, 0.035);
}

.event-head {
  display: block;
}

.event-main {
  min-width: 0;
}

.event-name {
  color: var(--wr-text, #0f1923);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.32;
}

.event-meta,
.summary,
.reason {
  margin-top: 8rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 25rpx;
  line-height: 1.5;
}

.event-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  column-gap: 28rpx;
  row-gap: 8rpx;
  margin-top: 16rpx;
}

.meta-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  color: var(--wr-muted, #6b7a8d);
  font-size: 24rpx;
  line-height: 1.35;
}

.meta-date {
  color: var(--wr-primary, #ff5c1a);
  font-weight: 700;
}

.meta-icon {
  width: 22rpx;
  height: 22rpx;
  flex: 0 0 22rpx;
}

.favorite {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
  min-height: 48rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: var(--wr-muted, #6b7a8d);
  padding: 0;
  line-height: 1;
  font-size: 24rpx;
}

.favorite.active {
  background: transparent;
  color: var(--wr-primary, #ff5c1a);
}

.favorite-icon {
  width: 26rpx;
  height: 26rpx;
}

.favorite-label {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.status-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.judgement {
  border: 2rpx solid var(--wr-tag-primary-border, #fed7aa);
  border-radius: 999rpx;
  background: var(--wr-tag-primary-bg, #fff7ed);
  color: var(--wr-tag-primary-text, #ea580c);
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.tag-row {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.summary {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.reason {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.tag {
  border-radius: 0;
  background: transparent;
  color: var(--wr-muted, #6b7a8d);
  padding: 0;
  font-size: 20rpx;
  opacity: 0.72;
}

.card-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
  border-top: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  padding-top: 20rpx;
}
