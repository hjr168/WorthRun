.event-card {
  border: 1rpx solid #e5edf0;
  border-radius: 18rpx;
  background: #ffffff;
  padding: 26rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.05);
}

.event-head {
  display: block;
}

.event-main {
  min-width: 0;
}

.event-name {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.32;
}

.event-meta,
.summary,
.reason {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
}

.favorite {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  width: 104rpx;
  height: 54rpx;
  border: 1rpx solid #d6e3e0;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #475569;
  padding: 0;
  line-height: 1;
  font-size: 22rpx;
}

.favorite.active {
  border-color: #2a9d8f;
  background: #eef6f5;
  color: #1f8a7f;
}

.favorite-icon {
  font-size: 24rpx;
  line-height: 1;
}

.favorite-label {
  font-size: 21rpx;
  line-height: 1;
}

.status-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.status,
.judgement {
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 24rpx;
}

.status {
  background: #f1f5f9;
  color: #1e293b;
}

.judgement {
  background: #eef6f5;
  color: #2a9d8f;
}

.tag-row {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  gap: 10rpx;
  min-width: 0;
}

.tag {
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  padding: 5rpx 12rpx;
  font-size: 23rpx;
}

.card-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}
