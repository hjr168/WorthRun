.event-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #ffffff;
  padding: 24rpx;
}

.event-head {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.event-main {
  flex: 1;
  min-width: 0;
}

.event-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.event-meta,
.summary,
.reason {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
}

.favorite {
  width: 104rpx;
  min-height: 58rpx;
  border: 1rpx solid #e2e8f0;
  background: #ffffff;
  color: #1e293b;
  padding: 0;
  font-size: 24rpx;
}

.favorite.active {
  border-color: #2a9d8f;
  color: #2a9d8f;
}

.status-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.status,
.judgement {
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 24rpx;
}

.status {
  background: #f1f5f9;
  color: #1e293b;
}

.judgement {
  background: #eef6f5;
  color: #2a9d8f;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  padding: 5rpx 12rpx;
  font-size: 23rpx;
}
