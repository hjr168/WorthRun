<view class="event-card" bindtap="onOpen">
  <view class="event-head">
    <view class="event-main">
      <view class="event-name">{{event.eventName}}</view>
      <view class="event-meta">{{event.city}} · {{dateText}} · {{distanceText}}</view>
    </view>
  </view>
  <view class="status-row">
    <text class="status">{{signupText}}</text>
    <text class="judgement">{{judgementText}}</text>
  </view>
  <view wx:if="{{event.judgementSummary}}" class="summary">{{event.judgementSummary}}</view>
  <view wx:if="{{reasons.length}}" class="reasons">
    <view wx:for="{{reasons}}" wx:key="*this" class="reason">· {{item}}</view>
  </view>
  <view class="card-footer">
    <view class="tag-row">
      <text wx:for="{{tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <button wx:if="{{showFavorite}}" class="favorite {{event.isFavorite ? 'active' : ''}}" catchtap="onFavorite" aria-label="{{event.isFavorite ? '取消收藏' : '收藏赛事'}}">
      <text class="favorite-icon">{{event.isFavorite ? '★' : '☆'}}</text>
      <text class="favorite-label">{{event.isFavorite ? '已收藏' : '收藏'}}</text>
    </button>
  </view>
</view>
