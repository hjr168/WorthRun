.event-status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid transparent;
  border-radius: 999rpx;
  padding: 7rpx 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.tone-positive {
  border-color: #b8e5de;
  background: #dff5f1;
  color: #176f66;
}

.tone-urgent {
  border-color: #f2c8bc;
  background: #fff0eb;
  color: #a34830;
}

.tone-neutral {
  border-color: #d6e3e0;
  background: #eef6f5;
  color: #356b65;
}

.tone-muted {
  border-color: #dce5e3;
  background: #f4f7f6;
  color: #60736f;
}
