.event-status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.tone-positive {
  border-color: var(--wr-tag-positive-border, #a7f3d0);
  background: var(--wr-tag-positive-bg, #ecfdf5);
  color: var(--wr-tag-positive-text, #059669);
}

.tone-urgent {
  border-color: var(--wr-tag-primary-border, #fed7aa);
  background: var(--wr-tag-primary-bg, #fff7ed);
  color: var(--wr-tag-primary-text, #ea580c);
}

.tone-neutral {
  border-color: #d6e3e0;
  background: #eef6f5;
  color: #356b65;
}

.tone-muted {
  border-color: #dce5e3;
  background: #f4f7f6;
  color: #60736f;
}
