.preferences-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.preference-head {
  margin-bottom: 24rpx;
  border: 1rpx solid #17353b;
  border-radius: 18rpx;
  background: #122b32;
  padding: 30rpx 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.12);
}

.preference-head-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.preference-head-subtitle {
  margin-top: 10rpx;
  color: #c6d7d5;
  font-size: 25rpx;
  line-height: 1.5;
}

.form-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.error-tip {
  margin-bottom: 18rpx;
  border: 1rpx solid #fecaca;
  border-radius: 8rpx;
  background: #fef2f2;
  color: #b91c1c;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
}

.chip-section {
  margin-bottom: 26rpx;
}

.chip-section:last-child {
  margin-bottom: 0;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 999rpx;
  background: #ffffff;
  color: #334155;
  padding: 0 22rpx;
  font-size: 26rpx;
  line-height: 1.2;
}

.chip.selected {
  border-color: #2a9d8f;
  background: #e7f6f3;
  color: #17786d;
  font-weight: 700;
}

.actions {
  display: grid;
  gap: 16rpx;
  margin-top: 24rpx;
}

.actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  line-height: 1.2;
}
