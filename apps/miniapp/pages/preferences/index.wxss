.preferences-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.form-card {
  margin-top: 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.error-tip {
  margin-bottom: 18rpx;
  border: 1rpx solid #fecaca;
  border-radius: 8rpx;
  background: #fef2f2;
  color: #b91c1c;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
}

.chip-section {
  margin-bottom: 26rpx;
}

.chip-section:last-child {
  margin-bottom: 0;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 999rpx;
  background: #ffffff;
  color: #334155;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.2;
}

.chip.selected {
  border-color: #2a9d8f;
  background: #e7f6f3;
  color: #17786d;
  font-weight: 700;
}

.actions {
  display: grid;
  gap: 16rpx;
  margin-top: 24rpx;
}

.actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  line-height: 1.2;
}

.secondary-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.secondary-actions button {
  width: 100%;
  min-width: 0;
}
