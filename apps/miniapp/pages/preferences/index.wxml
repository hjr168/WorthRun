<view class="page">
  <loading-state wx:if="{{loading}}" text="正在读取偏好" />
  <block wx:else>
    <view class="form-card">
      <view class="field">
        <view class="field-label">常跑城市</view>
        <input class="input" value="{{citiesText}}" placeholder="如：广州、深圳" bindinput="onCitiesInput" />
      </view>
      <view class="field">
        <view class="field-label">目标距离</view>
        <input class="input" value="{{distancesText}}" placeholder="如：10K、半马、全马" bindinput="onDistancesInput" />
      </view>
      <view class="field">
        <view class="field-label">关注点</view>
        <input class="input" value="{{focusTagsText}}" placeholder="如：交通方便、新手友好、风景路线" bindinput="onFocusInput" />
      </view>
    </view>
    <view class="actions">
      <button class="primary-button" bindtap="save">保存偏好</button>
      <button class="secondary-button" bindtap="reset">重置</button>
      <button class="plain-button" bindtap="skip">跳过</button>
    </view>
  </block>
</view>
