<view class="page preferences-page">
  <loading-state wx:if="{{loading}}" text="正在读取偏好" />
  <block wx:else>
    <page-header title="跑赛偏好" subtitle="用几个标签帮首页优先展示更接近你的赛事。" />

    <view wx:if="{{error}}" class="error-tip">{{error}}</view>
    <view class="form-card">
      <view class="chip-section">
        <view class="field-label">常跑城市</view>
        <view class="chip-row">
          <button
            wx:for="{{cityChips}}"
            wx:key="label"
            class="chip {{item.selected ? 'selected' : ''}}"
            aria-label="{{item.label}}{{item.selected ? '，已选择' : '，未选择'}}"
            data-group="cities"
            data-value="{{item.label}}"
            bindtap="toggleChip"
          >
            {{item.label}}
          </button>
        </view>
      </view>
      <view class="chip-section">
        <view class="field-label">目标距离</view>
        <view class="chip-row">
          <button
            wx:for="{{distanceChips}}"
            wx:key="label"
            class="chip {{item.selected ? 'selected' : ''}}"
            aria-label="{{item.label}}{{item.selected ? '，已选择' : '，未选择'}}"
            data-group="distances"
            data-value="{{item.label}}"
            bindtap="toggleChip"
          >
            {{item.label}}
          </button>
        </view>
      </view>
      <view class="chip-section">
        <view class="field-label">关注点</view>
        <view class="chip-row">
          <button
            wx:for="{{focusChips}}"
            wx:key="label"
            class="chip {{item.selected ? 'selected' : ''}}"
            aria-label="{{item.label}}{{item.selected ? '，已选择' : '，未选择'}}"
            data-group="focusTags"
            data-value="{{item.label}}"
            bindtap="toggleChip"
          >
            {{item.label}}
          </button>
        </view>
      </view>
    </view>
    <view class="actions">
      <button class="primary-button" bindtap="save">保存偏好</button>
      <view class="secondary-actions">
        <button class="secondary-button" bindtap="reset">重置</button>
        <button class="plain-button" bindtap="skip">跳过</button>
      </view>
    </view>
  </block>
</view>
