.feedback-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.feedback-head {
  margin-bottom: 24rpx;
  border: 1rpx solid #17353b;
  border-radius: 18rpx;
  background: #122b32;
  padding: 30rpx 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.12);
}

.feedback-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.feedback-subtitle {
  margin-top: 10rpx;
  color: #c6d7d5;
  font-size: 25rpx;
  line-height: 1.5;
}

.form-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.field {
  margin-bottom: 26rpx;
}

.picker-box {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #f8fafc;
  padding: 18rpx;
  color: #1e293b;
  font-size: 28rpx;
}

.submit {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  min-height: 82rpx;
  line-height: 1.2;
}
