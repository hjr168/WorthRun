<view class="page feedback-page">
  <view class="feedback-head">
    <view class="feedback-title">反馈纠错</view>
    <view class="feedback-subtitle">赛事信息可能变化，发现问题可以直接告诉我们。</view>
  </view>

  <view wx:if="{{!hasEvent}}" class="select-event-card">
    <view class="select-event-title">先选择要反馈的赛事</view>
    <view class="select-event-desc">提交反馈需要关联具体赛事。请从赛事详情页点击“反馈纠错”。</view>
    <button class="secondary-button select-event-button" bindtap="goEvents">去选择赛事</button>
  </view>

  <view wx:else class="form-card">
    <view class="field">
      <view class="field-label">反馈类型</view>
      <picker range="{{feedbackTypes}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-box">{{feedbackTypes[typeIndex]}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="field-label">补充说明</view>
      <textarea class="textarea" value="{{content}}" placeholder="请说明你发现的问题" bindinput="onContentInput" />
    </view>
  </view>
  <button wx:if="{{hasEvent}}" class="primary-button submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">提交反馈</button>
</view>
