.favorites-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.favorites-head {
  margin-bottom: 24rpx;
  border: 1rpx solid #17353b;
  border-radius: 18rpx;
  background: #122b32;
  padding: 30rpx 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.12);
}

.favorites-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.favorites-subtitle {
  margin-top: 10rpx;
  color: #c6d7d5;
  font-size: 25rpx;
  line-height: 1.5;
}

.card-gap {
  display: block;
  margin-bottom: 16rpx;
}
