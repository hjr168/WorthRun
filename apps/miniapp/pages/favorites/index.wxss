.favorites-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.card-gap {
  position: relative;
  display: block;
  margin: 20rpx 0 16rpx;
}

.card-gap + .card-gap {
  margin-top: 0;
}

.source-review-tag {
  position: absolute;
  z-index: 2;
  top: 18rpx;
  right: 18rpx;
  border-radius: 999rpx;
  background: #fff0d6;
  color: #8c5a00;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}
