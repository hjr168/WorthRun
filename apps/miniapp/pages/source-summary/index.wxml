<view class="page source-summary-page">
  <loading-state wx:if="{{loading}}" text="正在加载来源摘要" />
  <block wx:elif="{{error}}">
    <empty-state title="来源摘要暂不可用" description="{{error}}" />
    <view class="error-actions">
      <button class="primary-button" bindtap="reload">重新加载</button>
      <button class="secondary-button" bindtap="backToEvent">返回赛事详情</button>
    </view>
  </block>

  <block wx:elif="{{item}}">
    <page-header kicker="信息来源摘要" title="{{item.event.eventName}}" subtitle="{{item.event.city}} · {{eventDateText}}" />

    <view wx:if="{{item.stale}}" class="stale-notice">
      来源近期有更新，本摘要正在复核，请以原始来源为准。
    </view>

    <view class="source-meta">
      <view class="meta-row"><text class="meta-label">来源</text><text class="meta-value">{{item.sourceName}}</text></view>
      <view wx:if="{{item.sourceTitle}}" class="meta-row"><text class="meta-label">来源标题</text><text class="meta-value">{{item.sourceTitle}}</text></view>
      <view class="meta-row"><text class="meta-label">抓取时间</text><text class="meta-value">{{fetchedAtText}}</text></view>
      <view class="meta-row meta-row-last"><text class="meta-label">生成依据</text><text class="meta-value">{{basisText}}</text></view>
    </view>

    <view class="content-section">
      <view class="section-title">内容摘要</view>
      <view class="summary-text">{{item.summary}}</view>
    </view>

    <view class="content-section">
      <view class="section-title">来源关键点</view>
      <view wx:for="{{item.keyPoints}}" wx:key="*this" class="key-point">
        <text class="key-index">{{index + 1}}</text>
        <text class="key-copy">{{item}}</text>
      </view>
    </view>

    <view class="content-section limitation-section">
      <view class="section-title">需要继续确认</view>
      <view class="summary-text">{{item.limitations || '来源未明确的信息请以前往官方页面为准。'}}</view>
    </view>

    <button class="primary-button source-button" bindtap="copySourceUrl">复制原始来源链接</button>
    <view class="compliance-notice">{{complianceNotice}}</view>
  </block>
</view>
