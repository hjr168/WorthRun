.checklist-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.checklist-head {
  margin-bottom: 24rpx;
  border: 1rpx solid #17353b;
  border-radius: 18rpx;
  background: #122b32;
  padding: 30rpx 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.12);
}

.checklist-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.checklist-subtitle {
  margin-top: 10rpx;
  color: #c6d7d5;
  font-size: 25rpx;
  line-height: 1.5;
}

.picker-box {
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  background: #ffffff;
  padding: 18rpx;
  color: #1e293b;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}
