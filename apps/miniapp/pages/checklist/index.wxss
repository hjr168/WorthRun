.checklist-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.picker-box {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  margin-top: 20rpx;
  justify-content: space-between;
  gap: 16rpx;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 24rpx;
  background: var(--wr-surface, #ffffff);
  padding: 16rpx 20rpx;
  color: var(--wr-text, #0f1923);
  font-size: 28rpx;
  box-shadow: none;
}

.picker-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-chevron {
  flex: 0 0 28rpx;
  width: 28rpx;
  height: 28rpx;
}
