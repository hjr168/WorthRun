.checklist-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.picker-box {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  margin-top: 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  background: #ffffff;
  padding: 16rpx 20rpx;
  color: #1e293b;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}
