<theme-shell title="赛前清单" show-back="{{true}}">
<view class="page checklist-page">
  <page-header title="赛前清单" subtitle="报名、领物、装备和风险项，按类型逐项确认。" />

  <picker range="{{groups}}" value="{{groupIndex}}" bindchange="onGroupChange">
    <view class="picker-box"><text class="picker-text">类型：{{groups[groupIndex]}}</text><image class="picker-chevron" src="/assets/icons/chevron-down.png" mode="aspectFit" /></view>
  </picker>

  <view class="section">
    <loading-state wx:if="{{loading}}" text="正在加载清单" />
    <block wx:elif="{{error}}">
      <empty-state title="请求失败" description="{{error}}" />
      <button class="secondary-button" bindtap="reload">重新加载</button>
    </block>
    <block wx:else>
      <checklist-block items="{{items}}" />
      <empty-state wx:if="{{!items.length}}" title="暂无清单" description="可以先按官方报名页逐项确认" />
    </block>
  </view>
</view>
</theme-shell>
