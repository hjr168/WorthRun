.choices-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.choice-filters {
  display: flex;
  width: 100%;
  gap: 8rpx;
  margin: 18rpx 0;
  border-radius: 24rpx;
  background: var(--wr-surface-soft, #eef0f3);
  padding: 8rpx;
  overflow: hidden;
}

.filter-button {
  flex: 1 1 0;
  min-width: 0;
  width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border: 0;
  border-radius: 16rpx;
  background: transparent;
  color: var(--wr-muted, #6b7a8d);
  padding: 0;
  font-size: 24rpx;
  line-height: 1.2;
  overflow: hidden;
}

.filter-button-label {
  display: block;
  width: 100%;
  text-align: center;
  white-space: nowrap;
}

.filter-button.active {
  background: var(--wr-surface, #ffffff);
  color: var(--wr-text, #0f1923);
  font-weight: 700;
  box-shadow: 0 2rpx 6rpx rgba(15, 25, 35, 0.08);
}

.choice-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-surface, #ffffff);
  padding: 20rpx;
}

.choice-main {
  flex: 1 1 0;
  min-width: 0;
}

.choice-main.unavailable {
  opacity: 0.72;
}

.choice-state {
  color: var(--wr-primary, #ff5c1a);
  font-size: 23rpx;
  font-weight: 700;
}

.choice-event {
  margin-top: 7rpx;
  color: var(--wr-text, #0f1923);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.4;
  overflow-wrap: break-word;
  word-break: normal;
}

.choice-meta,
.choices-note {
  margin-top: 7rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 23rpx;
  line-height: 1.5;
}

.remove-button {
  display: flex;
  flex: 0 0 104rpx;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  width: 104rpx;
  max-width: 104rpx;
  height: 72rpx;
  margin: 0 0 0 16rpx;
  border: 1rpx solid #fecaca;
  border-radius: 12rpx;
  background: #fef2f2;
  color: #b91c1c;
  padding: 0;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  overflow: hidden;
}

.remove-button-label {
  display: block;
  width: auto;
  text-align: center;
  white-space: nowrap;
}

.remove-button-hover {
  border-color: #fca5a5;
  background: #fee2e2;
}

.choices-note {
  margin-top: 24rpx;
  text-align: center;
}
