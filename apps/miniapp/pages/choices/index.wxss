.choices-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.choice-filters {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin: 18rpx 0;
}

.filter-button {
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border: 1rpx solid #dbe5e7;
  border-radius: 12rpx;
  background: #ffffff;
  color: #475569;
  padding: 10rpx 4rpx;
  font-size: 24rpx;
  line-height: 1.2;
}

.filter-button.active {
  border-color: #2a9d8f;
  background: #eaf7f5;
  color: #176f66;
  font-weight: 700;
}

.choice-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 112rpx;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  background: #ffffff;
  padding: 20rpx;
}

.choice-main {
  min-width: 0;
}

.choice-main.unavailable {
  opacity: 0.72;
}

.choice-state {
  color: #2a7f75;
  font-size: 23rpx;
  font-weight: 700;
}

.choice-event {
  margin-top: 7rpx;
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.4;
  overflow-wrap: break-word;
  word-break: normal;
}

.choice-meta,
.choices-note {
  margin-top: 7rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}

.remove-button {
  width: 112rpx;
  min-height: 88rpx;
  border: 1rpx solid #d8e1e5;
  border-radius: 10rpx;
  background: #ffffff;
  color: #64748b;
  padding: 0;
  font-size: 23rpx;
}

.choices-note {
  margin-top: 24rpx;
  text-align: center;
}
