<view class="page choices-page">
  <page-header title="我的选择" subtitle="管理想跑、观望和已报名赛事。具体选择仅你自己可见。" />

  <view class="choice-filters">
    <button wx:for="{{filters}}" wx:key="value" class="filter-button {{filter === item.value ? 'active' : ''}}" aria-label="{{item.label}}{{filter === item.value ? '，当前筛选' : ''}}" data-value="{{item.value}}" bindtap="changeFilter">
      <text class="filter-button-label">{{item.label}}</text>
    </button>
  </view>

  <loading-state wx:if="{{loading}}" text="正在加载我的选择" />
  <block wx:elif="{{error}}">
    <empty-state title="请求失败" description="{{error}}" />
    <button class="secondary-button" bindtap="reload">重新加载</button>
    <button class="plain-button feedback-problem-link" bindtap="reportProblem">反馈问题</button>
  </block>
  <block wx:else>
    <view wx:for="{{items}}" wx:key="id" class="choice-row">
      <view wx:if="{{item.eventAvailable}}" class="choice-main" data-id="{{item.eventId}}" bindtap="openEvent">
        <view class="choice-state">{{item.choiceText}}</view>
        <view class="choice-event">{{item.event.eventName}}</view>
        <view class="choice-meta">{{item.event.city}} · {{item.dateText}} · {{item.distanceText}}</view>
      </view>
      <view wx:else class="choice-main unavailable">
        <view class="choice-state">{{item.choiceText}}</view>
        <view class="choice-event">赛事已不可用</view>
        <view class="choice-meta">已隐藏赛事详情，仍可清除本地选择。</view>
      </view>
      <button class="remove-button" hover-class="remove-button-hover" aria-label="清除这条选择" data-id="{{item.eventId}}" catchtap="removeChoice">
        <text class="remove-button-label">清除</text>
      </button>
    </view>
    <view wx:if="{{!items.length}}" bindtap="openEvents">
      <empty-state title="暂无选择" description="打开赛事详情，标记想跑、观望或已报名" />
    </view>
  </block>

  <view class="choices-note">匿名意向统计，不代表官方报名人数。</view>
</view>
