.detail-page {
  width: 100%;
  max-width: 100%;
  padding-top: 0;
  padding-bottom: 136rpx;
  padding-bottom: calc(136rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(136rpx + env(safe-area-inset-bottom));
}

.detail-page .section {
  margin-top: 24rpx;
}

.detail-page .card,
.choice-panel,
.ai-card {
  width: 100%;
  max-width: 100%;
  border-color: var(--wr-border, #e5edf0);
  border-radius: 24rpx;
  box-shadow: var(--wr-shadow, 0 6rpx 18rpx rgba(15, 23, 42, 0.04));
}

.reload-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 24rpx;
}

.title-card {
  width: 100%;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-hero, #ffffff);
  padding: 32rpx 28rpx 26rpx;
  box-shadow: 0 3rpx 8rpx rgba(15, 25, 35, 0.035);
}

.event-name {
  color: var(--wr-hero-text, #0f1923);
  font-size: 39rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow-wrap: break-word;
}

.core-info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.core-info-item {
  display: flex;
  min-width: 0;
  flex-direction: column;
  border: 0;
  border-radius: 24rpx;
  background: var(--wr-surface-soft, #eef0f3);
  padding: 14rpx 16rpx;
}

.core-info-wide {
  grid-column: 1 / -1;
}

.core-info-label {
  color: var(--wr-hero-muted, #6b7a8d);
  font-size: 21rpx;
  line-height: 1.3;
}

.core-info-value {
  margin-top: 5rpx;
  color: var(--wr-hero-text, #0f1923);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
  overflow-wrap: break-word;
}

.title-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
}

.updated-at {
  min-width: 0;
  color: var(--wr-hero-muted, #6b7a8d);
  font-size: 21rpx;
  line-height: 1.4;
  text-align: right;
}

.event-notice {
  width: 100%;
  margin-top: 18rpx;
  border: 2rpx solid #d8e8e5;
  border-radius: 24rpx;
  padding: 17rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.notice-review {
  border-color: #f0ddba;
  background: #fff8eb;
  color: #79531d;
}

.notice-pending {
  border-color: #f0ddba;
  background: #fff8eb;
  color: #79531d;
}

.info-card {
  overflow: hidden;
  padding: 0;
  padding-bottom: 10rpx;
}

.info-section > .section-title {
  color: var(--wr-muted, #6b7a8d);
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

.info-card .info-row {
  padding-right: 32rpx;
  padding-left: 32rpx;
}

.info-card .source-summary-entry {
  margin: 16rpx;
  width: auto;
}

.info-row,
.ai-info-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  border-bottom: 1rpx solid var(--wr-border, #e2e8f0);
  padding: 18rpx 0;
  color: var(--wr-muted, #6b7a8d);
  font-size: 26rpx;
}

.info-label,
.ai-info-label {
  flex: 0 0 136rpx;
  color: var(--wr-muted, #6b7a8d);
  white-space: nowrap;
}

.info-value,
.ai-info-value {
  flex: 1;
  min-width: 0;
  color: var(--wr-text, #0f1923);
  line-height: 1.5;
  overflow-wrap: break-word;
  word-break: normal;
  text-align: right;
}

.source-summary-entry,
.feedback-link,
.choice-heading,
.source-summary-side,
.ai-card-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.source-summary-entry {
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-height: 96rpx;
  border-radius: 12rpx;
  background: var(--wr-surface-soft, #eef0f3);
  color: var(--wr-text, #0f1923);
  padding: 14rpx 18rpx;
  text-align: left;
}

.detail-entry-hover {
  background: #eaf7f5;
}

.source-summary-copy,
.ai-card-heading {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.source-summary-title {
  font-size: 26rpx;
  font-weight: 800;
}

.source-summary-desc,
.choice-subtitle,
.choice-note {
  color: var(--wr-muted, #6b7a8d);
  font-size: 23rpx;
  line-height: 1.5;
}

.source-summary-desc,
.choice-subtitle {
  margin-top: 5rpx;
}

.source-summary-side {
  flex: 0 0 auto;
  gap: 10rpx;
  margin-left: 16rpx;
}

.source-summary-stale {
  border-radius: 999rpx;
  background: #fff1d6;
  color: #8c5a00;
  padding: 5rpx 12rpx;
  font-size: 21rpx;
}

.source-summary-action {
  color: var(--wr-primary, #ff5c1a);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.3;
}

.feedback-link {
  display: flex;
  box-sizing: border-box;
  align-items: center;
  width: 100%;
  max-width: 100%;
  min-height: 88rpx;
  background: transparent;
  color: var(--wr-primary, #ff5c1a);
  padding: 0 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: left;
}

.feedback-link-text {
  display: block;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-link-hover {
  background: #f2faf8;
}

.choice-panel {
  box-sizing: border-box;
  min-width: 0;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  background: var(--wr-surface, #ffffff);
  padding: 24rpx;
}

.choice-heading {
  gap: 18rpx;
}

.choice-heading .section-title {
  margin-bottom: 0;
}

.choice-updating {
  flex: 0 0 auto;
  color: #2a7f75;
  font-size: 23rpx;
}

.choice-empty {
  margin-top: 20rpx;
  border-radius: 12rpx;
  background: #f6faf9;
  color: #526e69;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
}

.choice-options {
  display: flex;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  align-items: stretch;
  overflow: hidden;
  margin-top: 18rpx;
}

.choice-option {
  position: relative;
  display: flex;
  box-sizing: border-box;
  width: 0;
  min-width: 0;
  max-width: 100%;
  min-height: 96rpx;
  flex: 1 1 0;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 24rpx;
  background: var(--wr-surface, #ffffff);
  color: var(--wr-text, #0f1923);
  padding: 12rpx 4rpx;
  line-height: 1.2;
  text-align: center;
}

.choice-option + .choice-option {
  margin-left: 12rpx;
}

.choice-option.active {
  border: 2rpx solid var(--wr-primary, #ff5c1a);
  background: var(--wr-primary-soft, #fff1eb);
  color: var(--wr-primary, #ff5c1a);
}

.choice-option.is-disabled {
  opacity: 0.75;
}

.choice-label,
.choice-count {
  display: block;
  width: 100%;
  min-width: 0;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.choice-label {
  margin-top: 4rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 22rpx;
  font-weight: 600;
}

.choice-count {
  margin-top: 0;
  color: #2583c4;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.1;
}

.choice-option + .choice-option .choice-count { color: #8264c8; }
.choice-option + .choice-option + .choice-option .choice-count { color: #23946f; }

.choice-note {
  margin-top: 16rpx;
}

.line {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.ai-card {
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  background: var(--wr-surface, #ffffff);
}

.ai-card-toggle {
  display: flex;
  box-sizing: border-box;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  min-height: 100rpx;
  background: var(--wr-surface-soft, #eef0f3);
  color: var(--wr-text, #0f1923);
  padding: 18rpx 22rpx;
  text-align: left;
}

.ai-card-toggle-hover {
  background: #eef8f6;
}

.ai-card-title {
  font-size: 28rpx;
  font-weight: 800;
}

.ai-card-subtitle {
  margin-top: 6rpx;
  color: #60736f;
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-card-action {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #2a7f75;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.ai-card-content {
  border-top: 1rpx solid #e2e8f0;
  padding: 8rpx 22rpx 22rpx;
}

.ai-info-row-last {
  border-bottom: 0;
}

.verification-group {
  margin-top: 18rpx;
}

.verification-title {
  color: #334155;
  font-size: 24rpx;
  font-weight: 700;
}

.verification-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.verification-tag {
  border-radius: 999rpx;
  padding: 5rpx 12rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.verification-tag.confirmed {
  background: #eaf7f5;
  color: #176f66;
}

.verification-tag.pending {
  background: #f2f5f4;
  color: #60736f;
}

.verification-empty {
  margin-top: 9rpx;
  color: #7a8b88;
  font-size: 22rpx;
  line-height: 1.45;
}

.verification-empty.no-records {
  margin-top: 18rpx;
}

.ai-disclaimer {
  margin-top: 20rpx;
  border-top: 1rpx solid #e2e8f0;
  color: #60736f;
  padding-top: 18rpx;
  font-size: 23rpx;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  z-index: 20;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 96rpx 96rpx minmax(0, 1fr);
  gap: 24rpx;
  border-top: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  background: var(--wr-surface, #ffffff);
  padding: 32rpx 40rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.bottom-bar .bottom-secondary,
.bottom-bar .bottom-primary {
  display: flex;
  width: 100%;
  min-width: 0;
  min-height: 88rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 2rpx;
  border-radius: 24rpx;
  padding: 0 8rpx;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.bottom-primary {
  grid-column: auto;
  flex-direction: row !important;
  font-size: 28rpx !important;
}

.bottom-favorite {
  border: 2rpx solid transparent;
}

.bottom-action-icon {
  width: 32rpx;
  height: 32rpx;
}

.bottom-favorite.favorite-idle {
  border-color: var(--wr-border, #b8dcd7);
  background: var(--wr-surface-soft, #eef0f3);
  color: var(--wr-muted, #6b7a8d);
}

.bottom-favorite.favorite-active {
  border-color: var(--wr-primary, #ff5c1a);
  background: var(--wr-primary-soft, #fff1eb);
  color: var(--wr-primary, #ff5c1a);
}

@media (max-width: 340px) {
  .bottom-bar {
    padding-right: 14rpx;
    padding-left: 14rpx;
  }

  .bottom-bar .bottom-secondary,
  .bottom-bar .bottom-primary {
    font-size: 22rpx;
  }
}
.reminder-panel { border-top: 2rpx solid rgba(15,25,35,.08); padding-top: 24rpx; }
.reminder-subtitle { margin-top: -6rpx; color: #64748b; font-size: 23rpx; }
.reminder-options { display: grid; gap: 12rpx; margin-top: 16rpx; }
.reminder-option { display: flex; align-items: center; gap: 18rpx; border: 2rpx solid rgba(15,25,35,.08); border-radius: 20rpx; background: #fff; padding: 20rpx; }
.reminder-copy { flex: 1; min-width: 0; }
.reminder-name { color: #0f1923; font-size: 27rpx; font-weight: 700; }
.reminder-desc { margin-top: 5rpx; color: #64748b; font-size: 22rpx; }
.reminder-button { flex: 0 0 120rpx; min-height: 64rpx; border: 2rpx solid #ff5c1a; background: #fff; color: #ff5c1a; padding: 8rpx 14rpx; font-size: 23rpx; font-weight: 700; }
.reminder-button.is-on { border-color: #b8d9d3; background: #eef8f6; color: #2a7f75; }
