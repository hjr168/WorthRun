.detail-page {
  width: 100%;
  max-width: 100%;
  padding-bottom: 136rpx;
  padding-bottom: calc(136rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(136rpx + env(safe-area-inset-bottom));
}

.detail-page .section {
  margin-top: 24rpx;
}

.detail-page .card,
.choice-panel,
.ai-card {
  width: 100%;
  max-width: 100%;
  border-color: #e5edf0;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.reload-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 24rpx;
}

.title-card {
  width: 100%;
  overflow: hidden;
  border: 1rpx solid #18343b;
  border-radius: 18rpx;
  background: #122b32;
  padding: 32rpx 28rpx 26rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.14);
}

.event-name {
  color: #ffffff;
  font-size: 39rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow-wrap: break-word;
}

.core-info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.core-info-item {
  display: flex;
  min-width: 0;
  flex-direction: column;
  border: 1rpx solid rgba(255, 255, 255, 0.13);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.07);
  padding: 14rpx 16rpx;
}

.core-info-wide {
  grid-column: 1 / -1;
}

.core-info-label {
  color: #9fb4b2;
  font-size: 21rpx;
  line-height: 1.3;
}

.core-info-value {
  margin-top: 5rpx;
  color: #f4f8f7;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
  overflow-wrap: break-word;
}

.title-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
}

.updated-at {
  min-width: 0;
  color: #b9ccca;
  font-size: 21rpx;
  line-height: 1.4;
  text-align: right;
}

.event-notice {
  width: 100%;
  margin-top: 18rpx;
  border: 1rpx solid #d8e8e5;
  border-radius: 14rpx;
  padding: 17rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.notice-review {
  border-color: #f0ddba;
  background: #fff8eb;
  color: #79531d;
}

.notice-pending {
  background: #f2f8f7;
  color: #4c6d68;
}

.info-card {
  padding-bottom: 10rpx;
}

.info-row,
.ai-info-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  border-bottom: 1rpx solid #e2e8f0;
  padding: 18rpx 0;
  color: #64748b;
  font-size: 26rpx;
}

.info-label,
.ai-info-label {
  flex: 0 0 136rpx;
  color: #64748b;
  white-space: nowrap;
}

.info-value,
.ai-info-value {
  flex: 1;
  min-width: 0;
  color: #1e293b;
  line-height: 1.5;
  overflow-wrap: break-word;
  word-break: normal;
  text-align: right;
}

.source-summary-entry,
.feedback-link,
.choice-heading,
.source-summary-side,
.ai-card-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.source-summary-entry {
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-height: 96rpx;
  border-radius: 12rpx;
  background: #f2faf8;
  color: #17353b;
  padding: 14rpx 18rpx;
  text-align: left;
}

.detail-entry-hover {
  background: #eaf7f5;
}

.source-summary-copy,
.ai-card-heading {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.source-summary-title {
  font-size: 26rpx;
  font-weight: 800;
}

.source-summary-desc,
.choice-subtitle,
.choice-note {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}

.source-summary-desc,
.choice-subtitle {
  margin-top: 5rpx;
}

.source-summary-side {
  flex: 0 0 auto;
  gap: 10rpx;
  margin-left: 16rpx;
}

.source-summary-stale {
  border-radius: 999rpx;
  background: #fff1d6;
  color: #8c5a00;
  padding: 5rpx 12rpx;
  font-size: 21rpx;
}

.source-summary-action {
  color: #2a7f75;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.3;
}

.feedback-link {
  display: flex;
  box-sizing: border-box;
  align-items: center;
  width: 100%;
  max-width: 100%;
  min-height: 88rpx;
  background: transparent;
  color: #2a7f75;
  padding: 0 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: left;
}

.feedback-link-text {
  display: block;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-link-hover {
  background: #f2faf8;
}

.choice-panel {
  box-sizing: border-box;
  min-width: 0;
  overflow: hidden;
  border: 1rpx solid #dce9e7;
  background: #ffffff;
  padding: 24rpx;
}

.choice-heading {
  gap: 18rpx;
}

.choice-heading .section-title {
  margin-bottom: 0;
}

.choice-updating {
  flex: 0 0 auto;
  color: #2a7f75;
  font-size: 23rpx;
}

.choice-empty {
  margin-top: 20rpx;
  border-radius: 12rpx;
  background: #f6faf9;
  color: #526e69;
  padding: 16rpx 18rpx;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
}

.choice-options {
  display: flex;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  align-items: stretch;
  overflow: hidden;
  margin-top: 18rpx;
}

.choice-option {
  position: relative;
  display: flex;
  box-sizing: border-box;
  width: 0;
  min-width: 0;
  max-width: 100%;
  min-height: 96rpx;
  flex: 1 1 0;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1rpx solid #dbe5e7;
  border-radius: 14rpx;
  background: #f8fafb;
  color: #334155;
  padding: 12rpx 4rpx;
  line-height: 1.2;
  text-align: center;
}

.choice-option + .choice-option {
  margin-left: 12rpx;
}

.choice-option.active {
  border: 2rpx solid #2a9d8f;
  background: #eaf7f5;
  color: #176f66;
}

.choice-option.is-disabled {
  opacity: 0.75;
}

.choice-label,
.choice-count {
  display: block;
  width: 100%;
  min-width: 0;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.choice-label {
  font-size: 25rpx;
  font-weight: 700;
}

.choice-selected {
  position: absolute;
  top: 6rpx;
  right: 7rpx;
  border-radius: 999rpx;
  background: #2a9d8f;
  color: #ffffff;
  padding: 3rpx 7rpx;
  font-size: 17rpx;
  font-weight: 700;
}

.choice-count {
  margin-top: 7rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.choice-option.active .choice-count {
  color: #176f66;
}

.choice-note {
  margin-top: 16rpx;
}

.line {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.ai-card {
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  border: 1rpx solid #d8e8e5;
  background: #ffffff;
}

.ai-card-toggle {
  display: flex;
  box-sizing: border-box;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  min-height: 100rpx;
  background: #f8fdfc;
  color: #17353b;
  padding: 18rpx 22rpx;
  text-align: left;
}

.ai-card-toggle-hover {
  background: #eef8f6;
}

.ai-card-title {
  font-size: 28rpx;
  font-weight: 800;
}

.ai-card-subtitle {
  margin-top: 6rpx;
  color: #60736f;
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-card-action {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #2a7f75;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.ai-card-content {
  border-top: 1rpx solid #e2e8f0;
  padding: 8rpx 22rpx 22rpx;
}

.ai-info-row-last {
  border-bottom: 0;
}

.verification-group {
  margin-top: 18rpx;
}

.verification-title {
  color: #334155;
  font-size: 24rpx;
  font-weight: 700;
}

.verification-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.verification-tag {
  border-radius: 999rpx;
  padding: 5rpx 12rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.verification-tag.confirmed {
  background: #eaf7f5;
  color: #176f66;
}

.verification-tag.pending {
  background: #f2f5f4;
  color: #60736f;
}

.verification-empty {
  margin-top: 9rpx;
  color: #7a8b88;
  font-size: 22rpx;
  line-height: 1.45;
}

.verification-empty.no-records {
  margin-top: 18rpx;
}

.ai-disclaimer {
  margin-top: 20rpx;
  border-top: 1rpx solid #e2e8f0;
  color: #60736f;
  padding-top: 18rpx;
  font-size: 23rpx;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  z-index: 20;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: minmax(0, 0.78fr) minmax(0, 0.64fr) minmax(0, 1.6fr);
  gap: 10rpx;
  border-top: 1rpx solid #e2e8f0;
  background: rgba(255, 255, 255, 0.98);
  padding: 14rpx 20rpx 16rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.bottom-bar button {
  display: flex;
  width: 100%;
  min-width: 0;
  min-height: 88rpx;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  padding: 0 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.bottom-primary {
  grid-column: auto;
}

.bottom-favorite {
  border: 1rpx solid transparent;
}

.bottom-favorite.favorite-idle {
  border-color: #b8dcd7;
  background: #eef8f6;
  color: #1f7a70;
}

.bottom-favorite.favorite-active {
  border-color: #fed7aa;
  background: #fff7ed;
  color: #c2410c;
}

@media (max-width: 340px) {
  .bottom-bar {
    padding-right: 14rpx;
    padding-left: 14rpx;
  }

  .bottom-bar button {
    font-size: 22rpx;
  }
}
