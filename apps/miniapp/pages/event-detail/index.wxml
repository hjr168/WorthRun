<view class="page detail-page">
  <loading-state wx:if="{{loading}}" text="正在加载详情" />
  <empty-state wx:elif="{{error}}" title="赛事不存在或未发布" description="{{error}}" />

  <block wx:elif="{{event}}">
    <view class="title-card">
      <view class="event-name">{{event.eventName}}</view>
      <view class="event-meta">{{event.city}} · {{dateText}} · {{distanceText}}</view>
      <view class="status">{{signupText}}</view>
    </view>

    <view class="section">
      <judgement-card event="{{event}}" />
    </view>

    <view class="section card">
      <view class="section-title">赛事基础信息</view>
      <view class="info-row"><text>起点</text><text>{{event.startPoint || '待确认'}}</text></view>
      <view class="info-row"><text>终点</text><text>{{event.endPoint || '待确认'}}</text></view>
      <view class="info-row"><text>来源</text><text>{{event.sourceName}}</text></view>
      <view class="info-row"><text>更新时间</text><text>{{event.updatedAt || '待确认'}}</text></view>
    </view>

    <view class="section card">
      <view class="section-title">适合谁</view>
      <view wx:for="{{event.suitableFor}}" wx:key="*this" class="line">· {{item}}</view>
      <view wx:if="{{!event.suitableFor.length}}" class="muted">待补充</view>
    </view>

    <view class="section card">
      <view class="section-title">不太适合谁</view>
      <view wx:for="{{event.notSuitableFor}}" wx:key="*this" class="line">· {{item}}</view>
      <view wx:if="{{!event.notSuitableFor.length}}" class="muted">待补充</view>
    </view>

    <view class="section">
      <view class="section-title">报名前确认清单</view>
      <checklist-block items="{{event.checklistItems}}" />
    </view>

    <view wx:if="{{event.tags.length}}" class="section card">
      <view class="section-title">标签</view>
      <view class="tag-row">
        <text wx:for="{{event.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <view class="section notice">{{complianceNotice}}</view>
  </block>

  <view wx:if="{{event}}" class="bottom-bar">
    <button class="primary-button" bindtap="openOfficial">{{officialActionText}}</button>
    <button class="secondary-button" bindtap="toggleFavorite">{{isFavorite ? '取消收藏' : '收藏'}}</button>
    <button class="secondary-button" bindtap="openFeedback">反馈纠错</button>
  </view>
</view>
