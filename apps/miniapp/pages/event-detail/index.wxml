<view class="page detail-page">
  <loading-state wx:if="{{loading}}" text="正在加载详情" />
  <block wx:elif="{{error}}">
    <empty-state title="赛事不存在或未发布" description="{{error}}" />
    <button class="secondary-button reload-button" bindtap="reload">重新加载</button>
  </block>

  <block wx:elif="{{event}}">
    <view class="title-card">
      <view class="event-name">{{event.eventName}}</view>
      <view class="core-info-grid">
        <view class="core-info-item">
          <text class="core-info-label">比赛日期</text>
          <text class="core-info-value">{{dateText}}</text>
        </view>
        <view class="core-info-item">
          <text class="core-info-label">举办地点</text>
          <text class="core-info-value">{{event.city || '待确认'}}</text>
        </view>
        <view class="core-info-item core-info-wide">
          <text class="core-info-label">赛事距离</text>
          <text class="core-info-value">{{distanceText}}</text>
        </view>
      </view>
      <view class="title-footer">
        <event-status-tag signup-status="{{event.signupStatus}}" event-date="{{event.eventDate}}" />
        <text class="updated-at">数据更新 {{updatedAtText}}</text>
      </view>
    </view>

    <view wx:if="{{eventNotice}}" class="event-notice notice-{{eventNotice.tone}}">
      {{eventNotice.text}}
    </view>

    <view class="section card info-card">
      <view class="section-title">赛事基础信息</view>
      <view class="info-row"><text class="info-label">起点</text><text class="info-value">{{event.startPoint || '待确认'}}</text></view>
      <view class="info-row"><text class="info-label">终点</text><text class="info-value">{{event.endPoint || '待确认'}}</text></view>
      <view class="info-row"><text class="info-label">数据来源</text><text class="info-value">{{event.sourceName || '待确认'}}</text></view>
      <view class="info-row"><text class="info-label">最近检查</text><text class="info-value">{{sourceCheckedAtText}}</text></view>

      <view wx:if="{{event.hasSourceSummary}}" class="source-summary-entry" role="button" tabindex="0" hover-class="detail-entry-hover" bindtap="openSourceSummary" aria-label="查看来源详情">
        <view class="source-summary-copy">
          <text class="source-summary-title">查看来源详情</text>
          <text class="source-summary-desc">阅读已核对的来源内容摘要</text>
        </view>
        <view class="source-summary-side">
          <text wx:if="{{event.sourceSummaryStale}}" class="source-summary-stale">待复核</text>
          <text class="source-summary-action">查看</text>
        </view>
      </view>

      <view class="feedback-link" role="button" tabindex="0" hover-class="feedback-link-hover" bindtap="openFeedback" aria-label="发现赛事信息有误，反馈纠错">
        <text class="feedback-link-text">{{hasFeedbackReceipt ? '本机已提交过反馈' : '发现赛事信息有误？反馈纠错'}}</text>
      </view>
    </view>

    <view class="section choice-panel">
      <view class="choice-heading">
        <view>
          <view class="section-title">大家怎么选</view>
          <view class="choice-subtitle">选择匿名记录，具体用户不会公开</view>
        </view>
        <view wx:if="{{choiceUpdating}}" class="choice-updating">更新中</view>
      </view>
      <view wx:if="{{!hasChoiceCounts}}" class="choice-empty">暂时还没有人标记，成为第一个吧</view>
      <view class="choice-options">
        <button class="choice-option {{viewerChoice === 'interested' ? 'active' : ''}} {{choiceUpdating ? 'is-disabled' : ''}}" data-choice="interested" bindtap="onChoiceTap" disabled="{{choiceUpdating}}" aria-label="想跑{{hasChoiceCounts ? '，' + event.choiceCounts.interested + '人' : ''}}{{viewerChoice === 'interested' ? '，已选中' : ''}}">
          <text class="choice-label">想跑</text>
          <text wx:if="{{viewerChoice === 'interested'}}" class="choice-selected">已选</text>
          <text wx:if="{{hasChoiceCounts}}" class="choice-count">{{event.choiceCounts.interested}}</text>
        </button>
        <button class="choice-option {{viewerChoice === 'considering' ? 'active' : ''}} {{choiceUpdating ? 'is-disabled' : ''}}" data-choice="considering" bindtap="onChoiceTap" disabled="{{choiceUpdating}}" aria-label="观望{{hasChoiceCounts ? '，' + event.choiceCounts.considering + '人' : ''}}{{viewerChoice === 'considering' ? '，已选中' : ''}}">
          <text class="choice-label">观望</text>
          <text wx:if="{{viewerChoice === 'considering'}}" class="choice-selected">已选</text>
          <text wx:if="{{hasChoiceCounts}}" class="choice-count">{{event.choiceCounts.considering}}</text>
        </button>
        <button class="choice-option {{viewerChoice === 'registered' ? 'active' : ''}} {{choiceUpdating ? 'is-disabled' : ''}}" data-choice="registered" bindtap="onChoiceTap" disabled="{{choiceUpdating}}" aria-label="已报名{{hasChoiceCounts ? '，' + event.choiceCounts.registered + '人' : ''}}{{viewerChoice === 'registered' ? '，已选中' : ''}}">
          <text class="choice-label">已报名</text>
          <text wx:if="{{viewerChoice === 'registered'}}" class="choice-selected">已选</text>
          <text wx:if="{{hasChoiceCounts}}" class="choice-count">{{event.choiceCounts.registered}}</text>
        </button>
      </view>
      <view class="choice-note">匿名意向统计，不代表官方报名人数；“已报名”为用户自报。</view>
    </view>

    <view class="section">
      <judgement-card event="{{event}}" />
    </view>

    <view class="section card">
      <view class="section-title">适合谁</view>
      <view wx:for="{{event.suitableFor}}" wx:key="*this" class="line">· {{item}}</view>
      <view wx:if="{{!event.suitableFor.length}}" class="muted">待补充</view>
    </view>

    <view class="section card">
      <view class="section-title">不太适合谁</view>
      <view wx:for="{{event.notSuitableFor}}" wx:key="*this" class="line">· {{item}}</view>
      <view wx:if="{{!event.notSuitableFor.length}}" class="muted">待补充</view>
    </view>

    <view class="section">
      <view class="section-title">报名前确认清单</view>
      <checklist-block items="{{event.checklistItems}}" />
    </view>

    <view wx:if="{{event.tags.length}}" class="section card">
      <view class="section-title">标签</view>
      <view class="tag-row">
        <text wx:for="{{event.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <view class="section ai-card">
      <view class="ai-card-toggle" role="button" tabindex="0" hover-class="ai-card-toggle-hover" bindtap="toggleAiNotice" aria-label="{{aiExpanded ? '收起 AI 整理说明' : '展开 AI 整理说明'}}">
        <view class="ai-card-heading">
          <text class="ai-card-title">AI 整理说明</text>
          <text class="ai-card-subtitle">{{complianceNotice}}</text>
        </view>
        <text class="ai-card-action">{{aiExpanded ? '收起' : '展开'}}</text>
      </view>
      <view wx:if="{{aiExpanded}}" class="ai-card-content">
        <view class="ai-info-row"><text class="ai-info-label">数据来源</text><text class="ai-info-value">{{event.sourceName || '待确认'}}</text></view>
        <view class="ai-info-row"><text class="ai-info-label">信息状态</text><text class="ai-info-value">{{infoStatusText}}</text></view>
        <view class="ai-info-row ai-info-row-last"><text class="ai-info-label">最近检查</text><text class="ai-info-value">{{sourceCheckedAtText}}</text></view>

        <view wx:if="{{hasVerificationItems}}" class="verification-groups">
          <view class="verification-group">
            <view class="verification-title">已核实的信息</view>
            <view wx:if="{{confirmedItems.length}}" class="verification-tags">
              <text wx:for="{{confirmedItems}}" wx:key="*this" class="verification-tag confirmed">{{item}}</text>
            </view>
            <view wx:else class="verification-empty">暂无已核实的逐项记录</view>
          </view>
          <view class="verification-group">
            <view class="verification-title">尚待核实的信息</view>
            <view wx:if="{{pendingItems.length}}" class="verification-tags">
              <text wx:for="{{pendingItems}}" wx:key="*this" class="verification-tag pending">{{item}}</text>
            </view>
            <view wx:else class="verification-empty">暂无待核实的逐项记录</view>
          </view>
        </view>
        <view wx:else class="verification-empty no-records">暂无逐项核验记录</view>
        <view class="ai-disclaimer">{{complianceNotice}}</view>
      </view>
    </view>
  </block>

  <view wx:if="{{event}}" class="bottom-bar">
    <button class="bottom-secondary bottom-favorite {{isFavorite ? 'favorite-active' : 'favorite-idle'}}" bindtap="toggleFavorite" aria-label="{{isFavorite ? '取消收藏赛事' : '收藏赛事'}}">{{isFavorite ? '取消收藏' : '收藏'}}</button>
    <button class="secondary-button bottom-secondary" bindtap="openShareCard" aria-label="生成赛事分享卡">分享</button>
    <button class="primary-button bottom-primary" bindtap="openOfficial" aria-label="前往官方确认赛事信息">{{officialActionText}}</button>
  </view>
</view>
