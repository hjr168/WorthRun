.share-card-page {
  padding: 24rpx 20rpx 36rpx;
  padding-bottom: calc(36rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  background: #f8fafc;
  min-height: 100vh;
}

.canvas-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  overflow: hidden;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  background: #ffffff;
  padding: 14rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.08);
}

.share-canvas {
  display: block;
  max-width: 100%;
  border-radius: 12rpx;
  background: #ffffff;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-bottom: 8rpx;
}

.actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 12rpx;
  font-size: 27rpx;
  line-height: 1.2;
  text-align: center;
}

.notice {
  margin-top: 16rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.5;
}
