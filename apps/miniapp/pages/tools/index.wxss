.tools-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.tools-head {
  margin-bottom: 24rpx;
  border: 1rpx solid #17353b;
  border-radius: 18rpx;
  background: #122b32;
  padding: 30rpx 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.12);
}

.tools-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.tools-subtitle {
  margin-top: 10rpx;
  color: #c6d7d5;
  font-size: 25rpx;
  line-height: 1.5;
}

.tool-card {
  position: relative;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.tool-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  background: #eef6f5;
  color: #2a9d8f;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.tool-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}
