.tools-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.tool-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  width: 100%;
  min-height: 112rpx;
  margin-top: 16rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  background: #ffffff;
  color: #1e293b;
  padding: 20rpx 22rpx;
  text-align: left;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.tool-copy {
  flex: 1;
  min-width: 0;
}

.tool-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.tool-action {
  flex: 0 0 auto;
  color: #2a9d8f;
  font-size: 24rpx;
  font-weight: 700;
}
