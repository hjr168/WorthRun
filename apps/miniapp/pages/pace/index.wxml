<view class="page pace-page">
  <view class="pace-head">
    <view class="pace-head-title">配速计算器</view>
    <view class="pace-head-subtitle">输入距离和目标时间，快速估算平均配速。</view>
  </view>

  <view class="card input-card">
    <view class="field">
      <view class="field-label">距离（公里）</view>
      <input class="input pace-input distance-input" type="digit" value="{{distance}}" bindinput="onDistance" />
    </view>
    <view class="time-grid">
      <view class="time-field">
        <view class="field-label">小时</view>
        <input class="input pace-input time-input" type="number" value="{{hours}}" bindinput="onHours" />
      </view>
      <view class="time-field">
        <view class="field-label">分钟</view>
        <input class="input pace-input time-input" type="number" value="{{minutes}}" bindinput="onMinutes" />
      </view>
      <view class="time-field">
        <view class="field-label">秒</view>
        <input class="input pace-input time-input" type="number" value="{{seconds}}" bindinput="onSeconds" />
      </view>
    </view>
    <button class="primary-button calc" bindtap="calculate">计算</button>
  </view>

  <view class="card section result-card">
    <view class="section-title">平均配速</view>
    <view class="pace">{{paceText || '待计算'}}</view>
    <view class="section-title split-title">分段参考</view>
    <view wx:for="{{splits}}" wx:key="*this" class="split">{{item}}</view>
  </view>
</view>
