.pace-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.input-card,
.result-card {
  margin-top: 20rpx;
  border-color: #e5edf0;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.field {
  margin-bottom: 24rpx;
}

.pace-input {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.distance-input {
  text-align: left;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.time-field {
  min-width: 0;
}

.time-input {
  padding: 0 10rpx;
  text-align: center;
}

.calc {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  width: 100%;
  min-height: 88rpx;
  line-height: 1.2;
}

.pace {
  color: #2a9d8f;
  font-size: 44rpx;
  font-weight: 800;
}

.split-title {
  margin-top: 26rpx;
}

.split {
  border-bottom: 1rpx solid #e2e8f0;
  padding: 14rpx 0;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.5;
}
