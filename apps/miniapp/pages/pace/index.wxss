.field {
  margin-bottom: 24rpx;
}

.pace-input {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.distance-input {
  text-align: left;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.time-field {
  min-width: 0;
}

.time-input {
  padding: 0 10rpx;
  text-align: center;
}

.calc {
  margin-top: 24rpx;
  width: 100%;
  min-height: 78rpx;
  line-height: 78rpx;
}

.pace {
  color: #2a9d8f;
  font-size: 44rpx;
  font-weight: 800;
}

.split-title {
  margin-top: 26rpx;
}

.split {
  border-bottom: 1rpx solid #e2e8f0;
  padding: 14rpx 0;
  color: #64748b;
  font-size: 28rpx;
}
