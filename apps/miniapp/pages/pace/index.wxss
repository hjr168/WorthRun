.field {
  margin-bottom: 24rpx;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.calc {
  margin-top: 24rpx;
}

.pace {
  color: #2a9d8f;
  font-size: 44rpx;
  font-weight: 800;
}

.split-title {
  margin-top: 26rpx;
}

.split {
  border-bottom: 1rpx solid #e2e8f0;
  padding: 14rpx 0;
  color: #64748b;
  font-size: 28rpx;
}
