<theme-shell title="赛事列表">
<view class="page events-page">
  <view class="events-subtitle">按城市、距离和报名状态快速筛选</view>

  <view class="search-row">
    <view class="search-field"><view class="search-submit" role="button" bindtap="submitSearch" aria-label="提交搜索"><image class="search-field-icon" src="/assets/icons/search.png" mode="aspectFit" /></view><input class="search" value="{{search}}" focus="{{searchFocused}}" placeholder="搜索赛事名称 / 城市" confirm-type="search" bindinput="onSearch" bindconfirm="submitSearch" /></view>
  </view>

  <view class="filters">
    <view class="filter-grid">
      <picker range="{{cities}}" value="{{cityIndex}}" bindchange="onCityChange">
        <view class="filter-item"><text class="filter-text">城市：{{cities[cityIndex]}}</text><image class="filter-chevron" src="/assets/icons/chevron-down.png" mode="aspectFit" /></view>
      </picker>
      <picker range="{{distances}}" value="{{distanceIndex}}" bindchange="onDistanceChange">
        <view class="filter-item"><text class="filter-text">距离：{{distances[distanceIndex]}}</text><image class="filter-chevron" src="/assets/icons/chevron-down.png" mode="aspectFit" /></view>
      </picker>
      <picker range="{{signupLabels}}" value="{{signupIndex}}" bindchange="onSignupChange">
        <view class="filter-item"><text class="filter-text">报名：{{signupLabels[signupIndex]}}</text><image class="filter-chevron" src="/assets/icons/chevron-down.png" mode="aspectFit" /></view>
      </picker>
      <picker range="{{judgementLabels}}" value="{{judgementIndex}}" bindchange="onJudgementChange">
        <view class="filter-item"><text class="filter-text">判断：{{judgementLabels[judgementIndex]}}</text><image class="filter-chevron" src="/assets/icons/chevron-down.png" mode="aspectFit" /></view>
      </picker>
    </view>
    <view wx:if="{{hasActiveFilter}}" class="filter-actions">
      <button class="reset-button" bindtap="resetFilters"><image class="reset-icon" src="/assets/icons/rotate-ccw.png" mode="aspectFit" /><text>重置筛选</text></button>
    </view>
  </view>

  <view wx:if="{{didInitialLoad && !error}}" class="result-summary">
    <view class="result-count">{{resultText}}</view>
    <view class="active-filter">{{activeFilterText}}</view>
  </view>

  <loading-state wx:if="{{loading}}" text="正在加载赛事" />
  <block wx:elif="{{error}}">
    <empty-state title="请求失败" description="{{error}}" />
    <button class="secondary-button" bindtap="reload">重新加载</button>
    <button class="plain-button feedback-problem-link" bindtap="reportProblem">反馈问题</button>
  </block>
  <block wx:else>
    <event-card
      wx:for="{{events}}"
      wx:key="id"
      class="card-gap"
      event="{{item}}"
      bind:open="openEvent"
      bind:favorite="toggleFavorite"
    />
    <block wx:if="{{!events.length}}">
      <empty-state title="暂无赛事" description="换个城市、距离或报名状态再试试" />
      <button class="secondary-button empty-reset" bindtap="resetFilters">清除筛选</button>
    </block>
    <view wx:elif="{{loadingMore}}" class="load-more">正在加载更多...</view>
    <view wx:elif="{{events.length && !hasMore}}" class="load-more">没有更多了</view>
  </block>
</view>
</theme-shell>
