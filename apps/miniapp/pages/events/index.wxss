.events-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.filters {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 20rpx 0;
  border: 1rpx solid #e5edf0;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.search-row {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
}

.search {
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #f8fafc;
  padding: 0 22rpx;
  font-size: 28rpx;
}

.search-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 128rpx;
  min-height: 88rpx;
  padding: 0;
  font-size: 27rpx;
  line-height: 1.2;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 88rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #f8fafc;
  padding: 16rpx;
  color: #1e293b;
  font-size: 26rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
}

.result-summary {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.result-count {
  flex: 0 0 auto;
  color: #1e293b;
  font-size: 26rpx;
  font-weight: 700;
}

.active-filter {
  min-width: 0;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
  overflow-wrap: break-word;
  word-break: normal;
}

.reset-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 184rpx;
  min-height: 88rpx;
  padding: 0;
  color: #475569;
  font-size: 25rpx;
  line-height: 1.2;
}

.card-gap {
  display: block;
  margin-top: 0;
  margin-bottom: 16rpx;
}

.load-more {
  padding: 20rpx 0 8rpx;
  color: #64748b;
  font-size: 24rpx;
  text-align: center;
}

.empty-reset {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 220rpx;
  min-height: 88rpx;
  margin: 18rpx auto 0;
  line-height: 1.2;
}
