.filters {
  display: grid;
  grid-template-columns: 1fr 140rpx;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.search {
  min-height: 76rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 0 18rpx;
  font-size: 28rpx;
}

.search-button {
  min-height: 76rpx;
  line-height: 76rpx;
}

.filter-item {
  min-height: 72rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 18rpx;
  color: #1e293b;
  font-size: 26rpx;
}

.card-gap {
  display: block;
  margin-bottom: 16rpx;
}
