.events-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.events-subtitle {
  margin-top: 18rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 24rpx;
  line-height: 1.5;
}

.filters {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 24rpx 0 32rpx;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-surface, #ffffff);
  padding: 32rpx;
  box-shadow: 0 3rpx 8rpx rgba(15, 25, 35, 0.035);
}

.search-row {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
  margin-top: 18rpx;
}

.search-field {
  display: flex;
  flex: 1;
  min-width: 0;
  align-items: center;
  gap: 16rpx;
  min-height: 88rpx;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 24rpx;
  background: var(--wr-surface-soft, #eef0f3);
  padding: 0 24rpx;
}

.search-field-icon {
  width: 30rpx;
  height: 30rpx;
  flex: 0 0 30rpx;
}

.search-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 30rpx;
  width: 30rpx;
  height: 44rpx;
}

.search {
  flex: 1;
  min-width: 0;
  min-height: 84rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: var(--wr-text, #0f1923);
  padding: 0;
  font-size: 28rpx;
}

.search-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 128rpx;
  min-height: 88rpx;
  padding: 0;
  font-size: 27rpx;
  line-height: 1.2;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 88rpx;
  justify-content: space-between;
  gap: 12rpx;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 24rpx;
  background: var(--wr-surface-soft, #eef0f3);
  padding: 16rpx;
  color: var(--wr-text, #0f1923);
  font-size: 26rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-chevron {
  width: 26rpx;
  height: 26rpx;
  flex: 0 0 26rpx;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
}

.result-summary {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.result-count {
  flex: 0 0 auto;
  color: var(--wr-text, #0f1923);
  font-size: 26rpx;
  font-weight: 700;
}

.active-filter {
  min-width: 0;
  color: var(--wr-muted, #6b7a8d);
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
  overflow-wrap: break-word;
  word-break: normal;
}

.reset-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: auto;
  min-height: 48rpx;
  border: 0;
  background: transparent;
  padding: 0;
  color: var(--wr-muted, #6b7a8d);
  font-size: 25rpx;
  line-height: 1.2;
}

.reset-icon {
  width: 22rpx;
  height: 22rpx;
}

.card-gap {
  display: block;
  margin-top: 0;
  margin-bottom: 16rpx;
}

.load-more {
  padding: 20rpx 0 8rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 24rpx;
  text-align: center;
}

.empty-reset {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 220rpx;
  min-height: 88rpx;
  margin: 18rpx auto 0;
  line-height: 1.2;
}
