.filters {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-row {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
}

.search {
  flex: 1;
  min-width: 0;
  min-height: 76rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 0 22rpx;
  font-size: 28rpx;
}

.search-button {
  flex: 0 0 132rpx;
  min-height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  font-size: 27rpx;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.filter-item {
  min-height: 72rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 18rpx;
  color: #1e293b;
  font-size: 26rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-gap {
  display: block;
  margin-bottom: 16rpx;
}

.load-more {
  padding: 20rpx 0 8rpx;
  color: #64748b;
  font-size: 24rpx;
  text-align: center;
}
