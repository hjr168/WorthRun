.home-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.preference-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #dbe7e5;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 18rpx 20rpx;
}

.preference-empty {
  display: block;
}

.preference-title {
  margin-bottom: 14rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.preference-action {
  flex: 0 0 auto;
  color: #2a9d8f;
  font-size: 24rpx;
  font-weight: 700;
}

.preference-label {
  color: #64748b;
  font-size: 23rpx;
}

.preference-value {
  margin-top: 6rpx;
  color: #1e293b;
  font-size: 27rpx;
  line-height: 1.4;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 88rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.all-events-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  margin-top: 24rpx;
  line-height: 1.2;
}

.card-gap {
  display: block;
  margin-top: 0;
  margin-bottom: 16rpx;
}

.fallback-notice {
  margin-top: 18rpx;
  border: 1rpx solid #d8e8e5;
  border-left: 8rpx solid #2a9d8f;
  border-radius: 14rpx;
  background: #ffffff;
  padding: 18rpx 20rpx;
  color: #1e293b;
  font-size: 25rpx;
  line-height: 1.5;
}
