.hero {
  border-radius: 12rpx;
  background: #1e293b;
  padding: 34rpx 28rpx;
}

.hero-title {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-sub {
  margin-top: 12rpx;
  color: #cbd5e1;
  font-size: 26rpx;
}

.preference-card {
  margin-top: 24rpx;
  overflow: hidden;
}

.preference-title {
  margin-bottom: 14rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.actions,
.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.actions button,
.tool-grid button {
  width: 100%;
  min-width: 0;
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-gap {
  display: block;
  margin-bottom: 16rpx;
}

.fallback-notice {
  margin-top: 18rpx;
  border: 1rpx solid #bfdbfe;
  border-radius: 8rpx;
  background: #eff6ff;
  padding: 18rpx 20rpx;
  color: #1d4ed8;
  font-size: 25rpx;
  line-height: 1.5;
}
