.home-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.hero-kicker {
  color: var(--wr-primary, #ff5c1a);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.home-hero {
  margin-top: 24rpx;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-hero, #ffffff);
  box-shadow: 0 3rpx 8rpx rgba(15, 25, 35, 0.035);
}

.hero-accent {
  width: var(--wr-home-accent-width, 100%);
  height: 12rpx;
  margin: var(--wr-home-accent-margin, 0);
  border-radius: var(--wr-home-accent-radius, 0);
  background: var(--wr-primary, #ff5c1a);
}

.hero-content {
  padding: var(--wr-home-content-padding, 34rpx 40rpx 40rpx);
}

.hero-title {
  color: var(--wr-hero-text, #0f1923);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
}

.hero-emphasis {
  color: var(--wr-primary, #ff5c1a);
}

.hero-copy {
  margin: 16rpx 0 30rpx;
  color: var(--wr-hero-muted, #6b7a8d);
  font-size: 26rpx;
  line-height: 1.55;
}

.preference-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid var(--wr-border, #dbe7e5);
  border-radius: 24rpx;
  background: var(--wr-surface, #ffffff);
  padding: 18rpx 20rpx;
}

.preference-empty {
  display: block;
}

.preference-title {
  margin-bottom: 14rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.preference-action {
  flex: 0 0 auto;
  color: var(--wr-primary, #ff5c1a);
  font-size: 24rpx;
  font-weight: 700;
}

.preference-label {
  color: var(--wr-muted, #6b7a8d);
  font-size: 23rpx;
}

.preference-value {
  margin-top: 6rpx;
  color: var(--wr-text, #0f1923);
  font-size: 27rpx;
  line-height: 1.4;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.actions .primary-button,
.actions .secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 88rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.all-events-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  margin-top: 24rpx;
  line-height: 1.2;
}

.card-gap {
  display: block;
  margin-top: 0;
  margin-bottom: 16rpx;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-heading .section-title {
  margin-bottom: 0;
}

.section-link {
  display: inline-flex;
  align-items: center;
  gap: 2rpx;
  color: var(--wr-primary, #ff5c1a);
  font-size: 26rpx;
  font-weight: 600;
}

.section-link-icon {
  width: 30rpx;
  height: 30rpx;
}

.fallback-notice {
  margin-top: 18rpx;
  border: 1rpx solid #d8e8e5;
  border-left: 8rpx solid var(--wr-primary, #ff5c1a);
  border-radius: 14rpx;
  background: var(--wr-surface, #ffffff);
  padding: 18rpx 20rpx;
  color: var(--wr-text, #0f1923);
  font-size: 25rpx;
  line-height: 1.5;
}
