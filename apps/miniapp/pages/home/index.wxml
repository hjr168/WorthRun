<view class="page home-page">
  <page-header kicker="WorthRun" title="哪场值得跑" subtitle="大湾区未来赛事，先判断，再去官方确认。" compact="{{false}}" />

  <loading-state wx:if="{{loading}}" text="正在加载赛事" />
  <block wx:elif="{{error}}">
    <empty-state title="请求失败" description="{{error}}" />
    <button class="secondary-button" bindtap="reload">重新加载</button>
  </block>

  <block wx:else>
    <view wx:if="{{!preference}}" class="preference-strip preference-empty">
      <view class="preference-title">先选择城市和距离，帮你筛出更适合的赛事</view>
      <view class="actions">
        <button class="primary-button" bindtap="openPreference">设置跑赛偏好</button>
        <button class="secondary-button" bindtap="openEvents">先随便看看</button>
      </view>
    </view>
    <view wx:else class="preference-strip" bindtap="openPreference">
      <view>
        <view class="preference-label">当前偏好</view>
        <view class="preference-value">{{preferenceText}}</view>
      </view>
      <view class="preference-action">调整</view>
    </view>
    <view wx:if="{{fallbackNotice}}" class="fallback-notice">{{fallbackNotice}}</view>

    <view wx:if="{{priorityEvents.length}}" class="section">
      <view class="section-title">优先关注</view>
      <event-card
        wx:for="{{priorityEvents}}"
        wx:key="id"
        class="card-gap"
        event="{{item}}"
        bind:open="openEvent"
        bind:favorite="toggleFavorite"
      />
    </view>

    <view wx:if="{{closingEvents.length}}" class="section">
      <view class="section-title">即将截止</view>
      <event-card
        wx:for="{{closingEvents}}"
        wx:key="id"
        class="card-gap"
        event="{{item}}"
        bind:open="openEvent"
        bind:favorite="toggleFavorite"
      />
    </view>

    <view wx:if="{{recentEvents.length}}" class="section">
      <view class="section-title">近期赛事</view>
      <event-card
        wx:for="{{recentEvents}}"
        wx:key="id"
        class="card-gap"
        event="{{item}}"
        bind:open="openEvent"
        bind:favorite="toggleFavorite"
      />
    </view>

    <empty-state wx:if="{{!priorityEvents.length && !closingEvents.length && !recentEvents.length}}" title="暂无赛事" description="后台发布赛事后会出现在这里" />
    <button class="secondary-button all-events-button" bindtap="openEvents">查看全部赛事</button>
  </block>
</view>
