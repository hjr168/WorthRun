<theme-shell title="哪场值得跑" show-search="{{true}}" bind:search="openSearch">
<view class="page home-page">
  <view class="home-hero">
    <view class="hero-accent"></view>
    <view class="hero-content">
      <view class="hero-kicker">大湾区跑者指南</view>
      <view class="hero-title">未来赛事，<text class="hero-emphasis">先判断</text></view>
      <view class="hero-title">再去官方确认。</view>
      <view class="hero-copy">选好城市和距离，帮你筛出值得优先关注的赛事</view>
      <view class="actions">
        <button class="primary-button" bindtap="openPreference">设置跑赛偏好</button>
        <button class="secondary-button" bindtap="openEvents">先随便看看</button>
      </view>
    </view>
  </view>

  <loading-state wx:if="{{loading}}" text="正在加载赛事" />
  <block wx:elif="{{error}}">
    <empty-state title="请求失败" description="{{error}}" />
    <button class="secondary-button" bindtap="reload">重新加载</button>
    <button class="plain-button feedback-problem-link" bindtap="reportProblem">反馈问题</button>
  </block>

  <block wx:else>
    <view wx:if="{{preference}}" class="preference-strip" bindtap="openPreference">
      <view>
        <view class="preference-label">当前偏好</view>
        <view class="preference-value">{{preferenceText}}</view>
      </view>
      <view class="preference-action">调整</view>
    </view>
    <view wx:if="{{fallbackNotice}}" class="fallback-notice">{{fallbackNotice}}</view>

    <view wx:if="{{priorityEvents.length}}" class="section">
      <view class="section-heading">
        <view class="section-title">优先关注</view>
        <view class="section-link" role="button" bindtap="openEvents" aria-label="查看全部赛事"><text>全部赛事</text><image class="section-link-icon" src="/assets/icons/chevron-right-orange.png" mode="aspectFit" /></view>
      </view>
      <event-card
        wx:for="{{priorityEvents}}"
        wx:key="id"
        class="card-gap"
        event="{{item}}"
        bind:open="openEvent"
        bind:favorite="toggleFavorite"
      />
    </view>

    <view wx:if="{{closingEvents.length}}" class="section">
      <view class="section-title">即将截止</view>
      <event-card
        wx:for="{{closingEvents}}"
        wx:key="id"
        class="card-gap"
        event="{{item}}"
        bind:open="openEvent"
        bind:favorite="toggleFavorite"
      />
    </view>

    <view wx:if="{{recentEvents.length}}" class="section">
      <view class="section-title">近期赛事</view>
      <event-card
        wx:for="{{recentEvents}}"
        wx:key="id"
        class="card-gap"
        event="{{item}}"
        bind:open="openEvent"
        bind:favorite="toggleFavorite"
      />
    </view>

    <empty-state wx:if="{{!priorityEvents.length && !closingEvents.length && !recentEvents.length}}" title="暂无赛事" description="后台发布赛事后会出现在这里" />
  </block>
</view>
</theme-shell>
