<view class="page mine-page">
  <loading-state wx:if="{{loading}}" text="正在加载我的信息" />
  <block wx:elif="{{error}}">
    <empty-state title="请求失败" description="{{error}}" />
    <button class="secondary-button" bindtap="reload">重新加载</button>
  </block>
  <block wx:else>
    <view class="profile-card">
      <view class="profile-main">
        <view class="profile-kicker">我的跑赛档案</view>
        <view class="profile-title">匿名跑者</view>
        <view class="profile-desc">收藏、选择、偏好和反馈都使用匿名身份，不公开个人资料。</view>
      </view>
      <view class="identity-chip">{{shortUserKey}}</view>
    </view>

    <view class="summary-grid">
      <view class="summary-card" bindtap="openPreferences">
        <view class="summary-label">偏好摘要</view>
        <view class="summary-value">{{preferenceText}}</view>
        <view class="summary-action">调整偏好</view>
      </view>

      <view class="summary-card highlight" bindtap="openNextEvent">
        <view class="summary-label">我的下一场</view>
        <view wx:if="{{nextEvent}}">
          <view class="next-name">{{nextEvent.eventName}}</view>
          <view class="summary-value">{{nextEvent.city}} · {{nextEventDate}}</view>
        </view>
        <view wx:else class="summary-value">先收藏一场赛事</view>
        <view class="summary-action">{{nextEvent ? '查看详情' : '去看看'}}</view>
      </view>
    </view>

    <view class="menu">
      <view class="menu-button" role="button" tabindex="0" hover-class="menu-button-hover" bindtap="openChoices" aria-label="打开我的选择">
        <view class="menu-copy">
          <text class="menu-title">我的选择</text>
          <text class="menu-summary">想跑 {{choiceCounts.interested}} · 观望 {{choiceCounts.considering}} · 已报名 {{choiceCounts.registered}}</text>
        </view>
        <text class="menu-action">查看</text>
      </view>
      <view class="menu-button" role="button" tabindex="0" hover-class="menu-button-hover" bindtap="openFavorites" aria-label="打开我的收藏">
        <view class="menu-copy"><text class="menu-title">我的收藏</text><text class="menu-summary">集中查看已收藏赛事</text></view>
        <text class="menu-action">查看</text>
      </view>
      <view class="menu-button" role="button" tabindex="0" hover-class="menu-button-hover" bindtap="openFeedback" aria-label="打开赛事纠错">
        <view class="menu-copy"><text class="menu-title">赛事纠错</text><text class="menu-summary">提交赛事信息变化</text></view>
        <text class="menu-action">打开</text>
      </view>
      <view class="menu-button" role="button" tabindex="0" hover-class="menu-button-hover" bindtap="openPreferences" aria-label="打开偏好设置">
        <view class="menu-copy"><text class="menu-title">偏好设置</text><text class="menu-summary">调整城市、距离和关注点</text></view>
        <text class="menu-action">调整</text>
      </view>
      <view class="menu-button" role="button" tabindex="0" hover-class="menu-button-hover" bindtap="openTools" aria-label="打开跑前工具">
        <view class="menu-copy"><text class="menu-title">跑前工具</text><text class="menu-summary">配速估算与赛前清单</text></view>
        <text class="menu-action">打开</text>
      </view>
    </view>

    <view wx:if="{{feedbackReceipts.length}}" class="receipt-section">
      <view class="section-title">本机最近反馈</view>
      <view class="receipt-note">仅记录提交回执，不代表管理员处理进度。</view>
      <view wx:for="{{feedbackReceipts}}" wx:key="requestId" class="receipt-row {{index === 0 ? 'receipt-row-first' : ''}} {{index === feedbackReceipts.length - 1 ? 'receipt-row-last' : ''}}">
        <view class="receipt-main">
          <view class="receipt-event">{{item.eventName}}</view>
          <view class="receipt-meta">{{item.feedbackType}} · {{item.createdAtText}}</view>
        </view>
        <view class="receipt-status">已提交</view>
      </view>
    </view>

    <view wx:if="{{isDev}}" class="card section dev-tools">
      <view class="section-title">开发调试</view>
      <view class="muted">用于测试匿名身份、偏好和收藏流程。</view>
      <button class="secondary-button danger-button" bindtap="clearLocalUserData">清除本地用户数据</button>
    </view>

    <view class="card section compliance-card">
      <view class="section-title">关于与合规说明</view>
      <view class="muted">{{complianceNotice}}</view>
    </view>
  </block>
</view>
