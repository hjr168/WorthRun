.mine-page {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.profile-card {
  margin-top: 24rpx;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-hero, #ffffff);
  padding: 30rpx 28rpx 28rpx;
  box-shadow: 0 3rpx 8rpx rgba(15, 25, 35, 0.035);
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-layout { display: flex; align-items: center; gap: 24rpx; }
.profile-avatar { flex: 0 0 104rpx; width: 104rpx; height: 104rpx; border-radius: 50%; }
.profile-avatar-placeholder { display: flex; align-items: center; justify-content: center; background: #fff1eb; color: #ff5c1a; font-size: 38rpx; font-weight: 800; }
.profile-actions { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-top: 22rpx; }
.profile-action { min-height: 60rpx; background: transparent; color: #ff5c1a; padding: 8rpx 0; font-size: 24rpx; font-weight: 700; }
.registered-at { color: #6b7a8d; font-size: 21rpx; }

.profile-kicker {
  color: var(--wr-primary, #ff5c1a);
  font-size: 24rpx;
  font-weight: 700;
}

.profile-title {
  margin-top: 12rpx;
  color: var(--wr-hero-text, #0f1923);
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.profile-desc {
  margin-top: 12rpx;
  color: var(--wr-hero-muted, #6b7a8d);
  font-size: 26rpx;
  line-height: 1.5;
}

.identity-chip {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  margin-top: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: var(--wr-hero-muted, #6b7a8d);
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.summary-panel {
  margin-top: 24rpx;
  overflow: hidden;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-surface, #ffffff);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx 32rpx;
}

.summary-row + .summary-row {
  border-top: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
}

.summary-copy {
  flex: 1;
  min-width: 0;
}

.summary-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
}

.summary-value {
  margin-top: 10rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.45;
  overflow-wrap: break-word;
  word-break: normal;
}

.summary-action {
  flex: 0 0 auto;
  color: var(--wr-primary, #ff5c1a);
  font-size: 24rpx;
  font-weight: 700;
}

.next-name {
  margin-top: 10rpx;
  color: var(--wr-text, #0f1923);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.menu {
  display: flex;
  width: 100%;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  margin-top: 24rpx;
}

.menu-button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-sizing: border-box;
  align-self: stretch;
  flex: 0 0 auto;
  width: 100%;
  max-width: none;
  min-height: 96rpx;
  margin: 0;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-surface, #ffffff);
  color: var(--wr-text, #0f1923);
  padding: 18rpx 22rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: left;
  box-shadow: none;
}

.menu-button-hover {
  border-color: #c9e3df;
  background: #f5fbfa;
}

.menu-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 5rpx;
}

.menu-icon-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: var(--wr-primary-soft, #fff1eb);
}

.menu-icon {
  width: 32rpx;
  height: 32rpx;
}

.menu-chevron {
  flex: 0 0 32rpx;
  width: 32rpx;
  height: 32rpx;
}

.menu-title {
  color: var(--wr-text, #0f1923);
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
}

.menu-title-line { display: flex; align-items: center; gap: 12rpx; }
.new-badge { padding: 3rpx 11rpx; border-radius: 999rpx; color: #fff; background: #e76f51; font-size: 20rpx; line-height: 1.4; }

.menu-summary {
  color: var(--wr-muted, #6b7a8d);
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.4;
}

.menu-action {
  flex: 0 0 auto;
  color: var(--wr-primary, #ff5c1a);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.choice-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.choice-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 24rpx;
  background: var(--wr-surface, #ffffff);
  padding: 20rpx 8rpx;
}

.choice-stat-value {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.1;
}

.choice-stat-value.interested { color: #2583c4; }
.choice-stat-value.considering { color: #8264c8; }
.choice-stat-value.registered { color: #23946f; }
.choice-stat-label { margin-top: 6rpx; color: var(--wr-muted, #6b7a8d); font-size: 22rpx; }

.receipt-section {
  margin-top: 28rpx;
}

.receipt-note {
  margin-top: -6rpx;
  margin-bottom: 12rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.5;
}

.receipt-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #e5edf0;
  background: #ffffff;
  padding: 20rpx 22rpx;
}

.receipt-row-first {
  border-radius: 12rpx 12rpx 0 0;
}

.receipt-row-last {
  border-bottom: 0;
  border-radius: 0 0 12rpx 12rpx;
}

.receipt-main {
  min-width: 0;
}

.receipt-event {
  overflow: hidden;
  color: #1e293b;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.receipt-meta {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 23rpx;
}

.receipt-status {
  flex: 0 0 auto;
  color: #2a7f75;
  font-size: 23rpx;
  font-weight: 700;
}

.dev-tools {
  display: grid;
  gap: 16rpx;
}

.dev-tools,
.compliance-card {
  border-color: #e5edf0;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border-color: #fecaca;
  color: #b91c1c;
  min-height: 88rpx;
  line-height: 1.2;
}
