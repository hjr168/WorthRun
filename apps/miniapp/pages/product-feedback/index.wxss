.product-feedback-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.context-band {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #17735f;
  background: #f3f8f6;
  color: #45615a;
  font-size: 24rpx;
  line-height: 1.5;
}

.request-id {
  word-break: break-all;
}

.form-section {
  margin-top: 28rpx;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.field-label {
  margin-bottom: 16rpx;
  color: #17231f;
  font-size: 28rpx;
  font-weight: 600;
}

.field-row .field-label {
  margin-bottom: 0;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.type-option {
  min-width: 0;
  min-height: 76rpx;
  padding: 14rpx 12rpx;
  border: 2rpx solid #d8e2de;
  border-radius: 8rpx;
  background: #fff;
  color: #40504a;
  font-size: 26rpx;
  line-height: 1.35;
}

.type-option.selected {
  border-color: #17735f;
  background: #eef7f4;
  color: #115c4d;
  font-weight: 600;
}

.character-count {
  color: #76827e;
  font-size: 22rpx;
}

.character-count.invalid {
  color: #b54848;
}

.feedback-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 260rpx;
  padding: 22rpx;
}

.field-help {
  margin-top: 12rpx;
  color: #76827e;
  font-size: 22rpx;
  line-height: 1.5;
}

.submit {
  margin-top: 32rpx;
}

.submit.is-disabled {
  opacity: 0.55;
}

.success-panel {
  margin-top: 48rpx;
  text-align: center;
}

.success-mark {
  color: #17735f;
  font-size: 24rpx;
  font-weight: 600;
}

.success-title {
  margin-top: 14rpx;
  color: #17231f;
  font-size: 36rpx;
  font-weight: 700;
}

.success-desc {
  margin: 18rpx 0 32rpx;
  color: #68746f;
  font-size: 24rpx;
  line-height: 1.6;
}
