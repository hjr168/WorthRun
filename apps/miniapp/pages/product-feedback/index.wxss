.product-feedback-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.context-band {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 24rpx 0 0;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #17735f;
  background: #f3f8f6;
  color: #45615a;
  font-size: 24rpx;
  line-height: 1.5;
}

.context-section {
  margin-top: 24rpx;
}

.context-picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border: 1rpx solid #d8e2de;
  border-radius: 12rpx;
  background: #ffffff;
  padding: 0 22rpx;
}

.context-picker-value {
  min-width: 0;
  color: #17231f;
  font-size: 27rpx;
  font-weight: 600;
}

.context-picker-action {
  flex: 0 0 auto;
  margin-left: 20rpx;
  color: #17735f;
  font-size: 24rpx;
  font-weight: 600;
}

.context-input {
  min-height: 88rpx;
  margin-top: 14rpx;
  border-color: #d8e2de;
  font-size: 26rpx;
}

.request-id {
  word-break: break-all;
}

.form-section {
  margin-top: 28rpx;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.field-label {
  margin-bottom: 16rpx;
  color: #17231f;
  font-size: 28rpx;
  font-weight: 600;
}

.field-row .field-label {
  margin-bottom: 0;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

.type-option {
  display: flex;
  flex: 0 0 calc(50% - 8rpx);
  align-items: center;
  justify-content: center;
  min-width: 0;
  width: calc(50% - 8rpx);
  height: 80rpx;
  margin: 0;
  padding: 0 12rpx;
  border: 2rpx solid #d8e2de;
  border-radius: 12rpx;
  background: #fff;
  color: #40504a;
  font-size: 26rpx;
  line-height: 1.35;
  overflow: hidden;
}

.type-option:last-child {
  flex-basis: 100%;
  width: 100%;
}

.type-option-label {
  display: block;
  max-width: 100%;
  text-align: center;
  white-space: nowrap;
}

.type-option-hover {
  background: #f5f8f7;
}

.type-option.selected {
  border-color: #17735f;
  background: #eef7f4;
  color: #115c4d;
  font-weight: 600;
}

.character-count {
  color: #76827e;
  font-size: 22rpx;
}

.character-count.invalid {
  color: #b54848;
}

.feedback-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 260rpx;
  padding: 22rpx;
}

.field-help {
  margin-top: 12rpx;
  color: #76827e;
  font-size: 22rpx;
  line-height: 1.5;
}

.submit {
  margin-top: 32rpx;
}

.submit.is-disabled {
  opacity: 0.55;
}

.success-panel {
  margin-top: 48rpx;
  text-align: center;
}

.success-mark {
  color: #17735f;
  font-size: 24rpx;
  font-weight: 600;
}

.success-title {
  margin-top: 14rpx;
  color: #17231f;
  font-size: 36rpx;
  font-weight: 700;
}

.success-desc {
  margin: 18rpx 0 32rpx;
  color: #68746f;
  font-size: 24rpx;
  line-height: 1.6;
}
