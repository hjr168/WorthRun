page {
  min-height: 100%;
  background: #f8fafc;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 8rpx;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.card {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #ffffff;
  padding: 24rpx;
}

.muted {
  color: #64748b;
}

.primary-button {
  background: #2a9d8f;
  color: #ffffff;
}

.secondary-button {
  border: 1rpx solid #e2e8f0;
  background: #ffffff;
  color: #1e293b;
}

.plain-button {
  background: transparent;
  color: #2a9d8f;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  border-radius: 999rpx;
  background: #eef6f5;
  color: #2a9d8f;
  padding: 6rpx 14rpx;
  font-size: 24rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #64748b;
  font-size: 26rpx;
}

.input,
.textarea {
  width: 100%;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 18rpx;
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
}
