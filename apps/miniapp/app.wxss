page {
  min-height: 100%;
  background: #f4f5f7;
  color: #0f1923;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

image,
scroll-view,
swiper,
swiper-item {
  box-sizing: border-box;
}

button {
  margin: 0;
  min-width: 0;
  border-radius: 14rpx;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 0 40rpx calc(56rpx + constant(safe-area-inset-bottom));
  padding: 0 40rpx calc(56rpx + env(safe-area-inset-bottom));
  background: var(--wr-bg, #f4f5f7);
  color: var(--wr-text, #0f1923);
  overflow-x: hidden;
}

.section {
  margin-top: 24rpx;
}

.section-title {
  margin-bottom: 14rpx;
  color: var(--wr-text, #0f1923);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.card {
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 32rpx;
  background: var(--wr-surface, #ffffff);
  padding: 24rpx;
  box-shadow: 0 3rpx 8rpx rgba(15, 25, 35, 0.035);
}

.muted {
  color: var(--wr-muted, #6b7a8d);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  background: var(--wr-primary, #ff5c1a);
  color: #ffffff;
  font-weight: 700;
  line-height: 1.25;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 18rpx 24rpx;
  border: 2rpx solid var(--wr-card-border, rgba(15, 25, 35, 0.08));
  border-radius: 24rpx;
  background: var(--wr-surface, #ffffff);
  color: var(--wr-text, #0f1923);
  font-weight: 600;
  line-height: 1.25;
}

.plain-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 18rpx 24rpx;
  border-radius: 14rpx;
  background: transparent;
  color: var(--wr-primary, #ff5c1a);
  font-weight: 600;
  line-height: 1.25;
}

.feedback-problem-link {
  min-height: 64rpx;
  margin-top: 12rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  border: 2rpx solid var(--wr-tag-primary-border, #fed7aa);
  border-radius: 999rpx;
  background: var(--wr-tag-primary-bg, #fff7ed);
  color: var(--wr-tag-primary-text, #ea580c);
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  line-height: 1.35;
}

.field-label {
  margin-bottom: 12rpx;
  color: var(--wr-muted, #6b7a8d);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
}

.input,
.textarea {
  width: 100%;
  border: 1rpx solid var(--wr-border, #e2e8f0);
  border-radius: 14rpx;
  background: var(--wr-surface-soft, #eef0f3);
  color: var(--wr-text, #0f1923);
  padding: 18rpx;
  font-size: 28rpx;
}

.input {
  min-height: 88rpx;
}

.textarea {
  min-height: 180rpx;
}

.card-gap {
  display: block;
  margin-top: 16rpx;
}

.page-copy {
  color: var(--wr-muted, #6b7a8d);
  font-size: 26rpx;
  line-height: 1.65;
}

.theme-shell .page-header + .section,
.theme-shell .page-header + .filters,
.theme-shell .page-header + .card,
.theme-shell .page-header + .tool-card {
  margin-top: 28rpx;
}

.theme-dark .filters,
.theme-dark .form-card,
.theme-dark .form-section,
.theme-dark .summary-card,
.theme-dark .menu-button,
.theme-dark .choice-row,
.theme-dark .tool-card,
.theme-dark .picker-box,
.theme-dark .event-context,
.theme-dark .select-event-card,
.theme-dark .success-panel,
.theme-dark .source-meta,
.theme-dark .content-section,
.theme-dark .release-card,
.theme-dark .receipt-row,
.theme-dark .context-band,
.theme-dark .canvas-wrapper {
  border-color: var(--wr-border);
  background: var(--wr-surface);
  color: var(--wr-text);
  box-shadow: none;
}

.theme-dark .summary-value,
.theme-dark .summary-label,
.theme-dark .menu-title,
.theme-dark .next-name,
.theme-dark .tool-title,
.theme-dark .choice-event,
.theme-dark .event-context-name,
.theme-dark .select-event-title,
.theme-dark .success-title,
.theme-dark .release-title,
.theme-dark .receipt-event,
.theme-dark .meta-value,
.theme-dark .summary-text,
.theme-dark .context-picker-value {
  color: var(--wr-text);
}

.theme-dark .menu-summary,
.theme-dark .choice-meta,
.theme-dark .event-context-meta,
.theme-dark .select-event-desc,
.theme-dark .success-desc,
.theme-dark .field-help,
.theme-dark .release-summary,
.theme-dark .release-date,
.theme-dark .receipt-meta,
.theme-dark .meta-label,
.theme-dark .compliance-notice,
.theme-dark .notice,
.theme-dark .choices-note,
.theme-dark .load-more,
.theme-dark .active-filter {
  color: var(--wr-muted);
}

.theme-dark .notice-review {
  border-color: rgba(245, 158, 11, 0.28);
  background: rgba(245, 158, 11, 0.1);
  color: rgba(252, 211, 77, 0.82);
}

.theme-dark .notice-pending {
  border-color: rgba(245, 158, 11, 0.28);
  background: rgba(245, 158, 11, 0.1);
  color: rgba(252, 211, 77, 0.82);
}

.natural-wrap {
  overflow-wrap: break-word;
  word-break: normal;
}
