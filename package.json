{
  "name": "worth-running",
  "private": true,
  "version": "0.1.0",
  "description": "哪场值得跑 V0.1 monorepo",
  "scripts": {
    "dev": "pnpm --parallel --filter @worth-running/api --filter @worth-running/admin dev",
    "dev:api": "pnpm --filter @worth-running/api dev",
    "dev:admin": "pnpm --filter @worth-running/admin dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @worth-running/database db:generate",
    "db:migrate": "pnpm --filter @worth-running/database db:migrate",
    "db:seed": "pnpm --filter @worth-running/database db:seed",
    "db:import-events": "pnpm --filter @worth-running/database db:import-events",
    "admin:reset-password": "pnpm --filter @worth-running/database reset-admin-password",
    "event-source:run-due": "pnpm --filter @worth-running/api event-source:run-due",
    "data-quality:cleanup": "pnpm --filter @worth-running/api data-quality:cleanup",
    "data:import-chinaath-plan": "pnpm --filter @worth-running/api data:import-chinaath-plan",
    "event-source:bootstrap-v0.4.2": "pnpm --filter @worth-running/api event-source:bootstrap-v0.4.2",
    "data:backfill-candidate-confirmation-links": "pnpm --filter @worth-running/api data:backfill-candidate-confirmation-links",
    "feedback:maintenance": "pnpm --filter @worth-running/api feedback:maintenance",
    "source-summary:backfill": "pnpm --filter @worth-running/api source-summary:backfill"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@11.7.0"
}
