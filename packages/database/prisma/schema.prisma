generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishStatus {
  draft
  published
  hidden
  offline
  archived
}

enum InfoStatus {
  ai_generated
  pending_verify
  verified
  user_flagged
  source_error
}

enum RunJudgement {
  priority
  watch
  unverified
}

enum SignupStatus {
  signup_open
  closing_soon
  closed
  not_started
  unknown
}

enum SourceLevel {
  official
  trusted
  community
  secondary
  unknown
}

enum FeedbackStatus {
  pending
  handling
  resolved
  rejected
}

enum FeedbackScope {
  event_correction
  product_feedback
}

enum AdminRole {
  super_admin
  event_operator
  content_reviewer
  readonly
}

enum AdminStatus {
  active
  disabled
}

enum UserStatus {
  active
  disabled
}

enum AvatarUploadGrantStatus {
  pending
  consumed
  completed
  failed
}

enum EventReminderType {
  signup
  race_week
}

enum EventReminderTrigger {
  signup_open
  signup_deadline_3d
  race_week_7d
}

enum EventReminderStatus {
  pending
  sending
  sent
  cancelled
  expired
  failed
  review_required
}

enum EventSourceType {
  page_url
  chinaath_api
  world_athletics
  chinamarathon_sitemap
  search_query
  rss
}

enum EventSourceStatus {
  active
  paused
}

enum EventCandidateStatus {
  new
  needs_review
  accepted
  rejected
  merged
}

enum EventSourceRunTrigger {
  manual
  scheduled
}

enum EventSourceRunStatus {
  running
  succeeded
  failed
}

enum EventChangeAlertStatus {
  open
  applied
  dismissed
  archived_event
  superseded
}

enum EventChangeSeverity {
  normal
  important
  critical
}

enum EventInteractionAction {
  event_detail_view
  official_link_copy
  source_summary_open
  source_summary_view
  source_original_link_copy
}

enum EventChoiceType {
  interested
  considering
  registered
}

enum SourceSummaryStatus {
  draft
  published
  superseded
}

enum SourceSummaryBasis {
  page_text
  stored_source_record
}

enum ReleaseNoteStatus {
  draft
  published
  offline
}

model Event {
  id               String        @id @default(cuid())
  eventName        String        @map("event_name")
  city             String
  eventDate        DateTime      @map("event_date") @db.Date
  distanceItems    String[]      @map("distance_items")
  startPoint       String?       @map("start_point")
  endPoint         String?       @map("end_point")
  signupStatus     SignupStatus  @default(unknown) @map("signup_status")
  signupStartAt    DateTime?     @map("signup_start_at")
  signupDeadline   DateTime?     @map("signup_deadline")
  officialUrl      String        @map("official_url")
  sourceName       String        @map("source_name")
  sourceUrl        String?       @map("source_url")
  sourceLevel      SourceLevel   @default(unknown) @map("source_level")
  publishStatus    PublishStatus @default(draft) @map("publish_status")
  infoStatus       InfoStatus    @default(pending_verify) @map("info_status")
  runJudgement     RunJudgement  @default(unverified) @map("run_judgement")
  judgementSummary String?       @map("judgement_summary")
  judgementReasons String[]      @default([]) @map("judgement_reasons")
  suitableFor      String[]      @default([]) @map("suitable_for")
  notSuitableFor   String[]      @default([]) @map("not_suitable_for")
  tags             String[]      @default([])
  fieldConfidence  Json?         @map("field_confidence")
  sourceCheckedAt  DateTime?     @map("source_checked_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  publishedAt      DateTime?     @map("published_at")
  archivedAt       DateTime?     @map("archived_at")

  checklistItems  EventChecklistItem[]
  eventTags       EventTag[]
  favorites       UserFavorite[]
  feedback        Feedback[]
  shareRecords    ShareRecord[]
  interactions    EventInteraction[]
  changeAlerts    EventChangeAlert[]
  userChoices     UserEventChoice[]
  sourceSummaries EventSourceSummary[]
  shareOverride   EventShareOverride?
  reminders       EventReminder[]

  @@index([city])
  @@index([eventDate])
  @@index([publishStatus])
  @@index([signupStatus])
  @@map("events")
}

model EventChecklistItem {
  id          String     @id @default(cuid())
  eventId     String     @map("event_id")
  groupName   String     @map("group_name")
  itemName    String     @map("item_name")
  itemStatus  InfoStatus @default(pending_verify) @map("item_status")
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_checklist_items")
}

model EventTag {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  tagName   String   @map("tag_name")
  tagType   String   @default("experience") @map("tag_type")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_tags")
}

model UserPreference {
  id        String   @id @default(cuid())
  userKey   String   @unique @map("user_key")
  userId    String?  @map("user_id")
  cities    String[] @default([])
  distances String[] @default([])
  focusTags String[] @default([]) @map("focus_tags")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId])
  @@map("user_preferences")
}

model UserFavorite {
  id        String   @id @default(cuid())
  userKey   String   @map("user_key")
  userId    String?  @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userKey, eventId])
  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("user_favorites")
}

model UserEventChoice {
  id        String          @id @default(cuid())
  userKey   String          @map("user_key")
  userId    String?         @map("user_id")
  eventId   String          @map("event_id")
  choice    EventChoiceType
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userKey, eventId])
  @@unique([userId, eventId])
  @@index([userId])
  @@index([userKey, choice, updatedAt])
  @@index([eventId, choice])
  @@index([createdAt])
  @@map("user_event_choices")
}

model User {
  id               String     @id @default(cuid())
  openIdHash       String     @unique @map("open_id_hash")
  openIdCiphertext String     @map("open_id_ciphertext")
  openIdIv         String     @map("open_id_iv")
  openIdAuthTag    String     @map("open_id_auth_tag")
  nickname         String?
  avatarFileId     String?    @map("avatar_file_id")
  status           UserStatus @default(active)
  registeredAt     DateTime   @default(now()) @map("registered_at")
  lastLoginAt      DateTime   @default(now()) @map("last_login_at")
  lastActiveAt     DateTime   @default(now()) @map("last_active_at")
  profileUpdatedAt DateTime?  @map("profile_updated_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  aliases            UserAlias[]
  preferences        UserPreference[]
  favorites          UserFavorite[]
  choices            UserEventChoice[]
  feedback           Feedback[]
  shares             ShareRecord[]
  activities         UserActivityDaily[]
  reminders          EventReminder[]
  avatarUploadGrants AvatarUploadGrant[]

  @@index([status, registeredAt])
  @@index([lastActiveAt])
  @@index([nickname])
  @@map("users")
}

model UserAlias {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  userKeyHash String   @unique @map("user_key_hash")
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_aliases")
}

model UserActivityDaily {
  userId             String   @map("user_id")
  activityDate       DateTime @map("activity_date") @db.Date
  firstEntryPage     String?  @map("first_entry_page")
  firstChannel       String?  @map("first_channel")
  referralShareToken String?  @map("referral_share_token")
  viewedDetail       Boolean  @default(false) @map("viewed_detail")
  copiedOfficial     Boolean  @default(false) @map("copied_official")
  addedFavorite      Boolean  @default(false) @map("added_favorite")
  setChoice          Boolean  @default(false) @map("set_choice")
  startedShare       Boolean  @default(false) @map("started_share")
  subscribedReminder Boolean  @default(false) @map("subscribed_reminder")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, activityDate])
  @@index([activityDate])
  @@index([referralShareToken])
  @@map("user_activity_daily")
}

model AvatarUploadGrant {
  id          String                  @id @default(cuid())
  userId      String                  @map("user_id")
  tokenHash   String                  @unique @map("token_hash")
  status      AvatarUploadGrantStatus @default(pending)
  expiresAt   DateTime                @map("expires_at")
  consumedAt  DateTime?               @map("consumed_at")
  completedAt DateTime?               @map("completed_at")
  createdAt   DateTime                @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt, status])
  @@index([userId, createdAt])
  @@map("avatar_upload_grants")
}

model EventReminder {
  id            String               @id @default(cuid())
  userId        String               @map("user_id")
  eventId       String               @map("event_id")
  reminderType  EventReminderType    @map("reminder_type")
  trigger       EventReminderTrigger
  status        EventReminderStatus  @default(pending)
  scheduledAt   DateTime?            @map("scheduled_at")
  sentAt        DateTime?            @map("sent_at")
  cancelledAt   DateTime?            @map("cancelled_at")
  attempts      Int                  @default(0)
  lastErrorCode String?              @map("last_error_code")
  lockedAt      DateTime?            @map("locked_at")
  lockToken     String?              @map("lock_token")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId, reminderType])
  @@index([status, scheduledAt])
  @@index([eventId, status])
  @@map("event_reminders")
}

model EventSourceSummary {
  id            String              @id @default(cuid())
  eventId       String              @map("event_id")
  status        SourceSummaryStatus @default(draft)
  basis         SourceSummaryBasis
  sourceName    String              @map("source_name")
  sourceUrl     String              @map("source_url")
  sourceTitle   String?             @map("source_title")
  summary       String
  keyPoints     String[]            @map("key_points")
  limitations   String?
  contentHash   String              @map("content_hash")
  aiProvider    String              @map("ai_provider")
  aiModel       String              @map("ai_model")
  promptVersion String              @map("prompt_version")
  fetchedAt     DateTime            @map("fetched_at")
  generatedAt   DateTime            @default(now()) @map("generated_at")
  publishedAt   DateTime?           @map("published_at")
  staleAt       DateTime?           @map("stale_at")
  reviewedBy    String?             @map("reviewed_by")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, contentHash, promptVersion])
  @@index([eventId, status, updatedAt])
  @@index([status, staleAt])
  @@map("event_source_summaries")
}

model Feedback {
  id               String         @id @default(cuid())
  eventId          String?        @map("event_id")
  userKey          String?        @map("user_key")
  userId           String?        @map("user_id")
  scope            FeedbackScope  @default(event_correction)
  feedbackType     String         @map("feedback_type")
  content          String
  contextPage      String?        @map("context_page")
  appVersion       String?        @map("app_version")
  relatedRequestId String?        @map("related_request_id")
  requestId        String?        @unique @map("request_id")
  fingerprint      String?        @map("fingerprint")
  status           FeedbackStatus @default(pending)
  adminNote        String?        @map("admin_note")
  handledBy        String?        @map("handled_by")
  handledAt        DateTime?      @map("handled_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  event             Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user              User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  fingerprintRecord FeedbackFingerprint?

  @@index([status])
  @@index([eventId])
  @@index([userId])
  @@index([scope, status, createdAt])
  @@index([contextPage])
  @@index([fingerprint])
  @@map("feedback")
}

model ApiErrorMetric {
  bucketStart DateTime @map("bucket_start")
  routeGroup  String   @map("route_group")
  category    String
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id([bucketStart, routeGroup, category])
  @@index([bucketStart])
  @@map("api_error_metrics")
}

model FeedbackFingerprint {
  fingerprint String   @id
  feedbackId  String   @unique @map("feedback_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("feedback_fingerprints")
}

model FeedbackRateLimit {
  scope       String
  keyHash     String   @map("key_hash")
  windowStart DateTime @map("window_start")
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id([scope, keyHash, windowStart])
  @@index([windowStart])
  @@map("feedback_rate_limits")
}

model FeedbackAbuseMetric {
  day       DateTime @db.Date
  reason    String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([day, reason])
  @@index([day])
  @@map("feedback_abuse_metrics")
}

model AdminUser {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String      @map("password_hash")
  displayName  String      @map("display_name")
  role         AdminRole   @default(event_operator)
  status       AdminStatus @default(active)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  operationLogs AdminOperationLog[]

  @@map("admin_users")
}

model AdminOperationLog {
  id          String   @id @default(cuid())
  adminUserId String?  @map("admin_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_operation_logs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  configValue Json     @map("config_value")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model EventShareOverride {
  id            String   @id @default(cuid())
  eventId       String   @unique @map("event_id")
  titleTemplate String?  @map("title_template")
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_share_overrides")
}

model ReleaseNote {
  id          String            @id @default(cuid())
  version     String            @unique
  title       String
  summary     String?
  changes     Json
  status      ReleaseNoteStatus @default(draft)
  releasedAt  DateTime          @map("released_at")
  publishedAt DateTime?         @map("published_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([status, releasedAt])
  @@index([status, publishedAt])
  @@map("release_notes")
}

model EventSource {
  id                    String            @id @default(cuid())
  name                  String
  sourceType            EventSourceType   @default(page_url) @map("source_type")
  entryUrl              String?           @map("entry_url")
  searchQuery           String?           @map("search_query")
  allowedDomains        String[]          @default([]) @map("allowed_domains")
  cityHints             String[]          @default([]) @map("city_hints")
  sourceLevel           SourceLevel       @default(unknown) @map("source_level")
  status                EventSourceStatus @default(active)
  scheduleEnabled       Boolean           @default(false) @map("schedule_enabled")
  scheduleIntervalHours Int               @default(24) @map("schedule_interval_hours")
  pageSize              Int               @default(20) @map("page_size")
  maxPagesPerRun        Int               @default(1) @map("max_pages_per_run")
  nextPage              Int               @default(1) @map("next_page")
  nextRunAt             DateTime?         @map("next_run_at")
  lastRunAt             DateTime?         @map("last_run_at")
  lastRunStatus         String?           @map("last_run_status")
  lastSuccessAt         DateTime?         @map("last_success_at")
  consecutiveFailures   Int               @default(0) @map("consecutive_failures")
  runLockToken          String?           @map("run_lock_token")
  runLockExpiresAt      DateTime?         @map("run_lock_expires_at")
  notes                 String?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  candidates   EventCandidate[]
  runs         EventSourceRun[]
  changeAlerts EventChangeAlert[]

  @@index([status])
  @@index([status, scheduleEnabled, nextRunAt])
  @@map("event_sources")
}

model EventCandidate {
  id                    String               @id @default(cuid())
  sourceId              String?              @map("source_id")
  status                EventCandidateStatus @default(new)
  eventName             String               @map("event_name")
  city                  String
  eventDate             DateTime?            @map("event_date") @db.Date
  sourceUrl             String?              @map("source_url")
  officialUrl           String?              @map("official_url")
  extractedData         Json                 @map("extracted_data")
  evidence              Json
  confidence            Json?
  duplicateEventId      String?              @map("duplicate_event_id")
  acceptedEventId       String?              @map("accepted_event_id")
  mergedIntoCandidateId String?              @map("merged_into_candidate_id")
  aiModel               String?              @map("ai_model")
  aiPromptVersion       String?              @map("ai_prompt_version")
  sourceExternalId      String?              @map("source_external_id")
  rawPayload            Json?                @map("raw_payload")
  extractorVersion      String?              @map("extractor_version")
  priorityScore         Int                  @default(0) @map("priority_score")
  reviewIssues          String[]             @default([]) @map("review_issues")
  reviewedBy            String?              @map("reviewed_by")
  reviewedAt            DateTime?            @map("reviewed_at")
  rejectReason          String?              @map("reject_reason")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  source           EventSource?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  mergedInto       EventCandidate?    @relation("EventCandidateMerges", fields: [mergedIntoCandidateId], references: [id], onDelete: SetNull)
  mergedCandidates EventCandidate[]   @relation("EventCandidateMerges")
  changeAlerts     EventChangeAlert[]

  @@unique([sourceId, sourceExternalId])
  @@index([status])
  @@index([sourceId])
  @@index([mergedIntoCandidateId])
  @@index([eventName, city, eventDate])
  @@map("event_candidates")
}

model EventSourceRun {
  id                   String                @id @default(cuid())
  sourceId             String                @map("source_id")
  trigger              EventSourceRunTrigger
  status               EventSourceRunStatus  @default(running)
  startedAt            DateTime              @default(now()) @map("started_at")
  finishedAt           DateTime?             @map("finished_at")
  startPage            Int?                  @map("start_page")
  endPage              Int?                  @map("end_page")
  pageCount            Int                   @default(0) @map("page_count")
  totalAvailable       Int?                  @map("total_available")
  fetched              Int                   @default(0)
  created              Int                   @default(0)
  updated              Int                   @default(0)
  skippedReviewed      Int                   @default(0) @map("skipped_reviewed")
  skippedExpired       Int                   @default(0) @map("skipped_expired")
  skippedOutsideRegion Int                   @default(0) @map("skipped_outside_region")
  duplicateEvents      Int                   @default(0) @map("duplicate_events")
  changeAlertsCreated  Int                   @default(0) @map("change_alerts_created")
  changeAlertsExisting Int                   @default(0) @map("change_alerts_existing")
  errorMessage         String?               @map("error_message")
  createdAt            DateTime              @default(now()) @map("created_at")

  source       EventSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  changeAlerts EventChangeAlert[]

  @@index([sourceId, startedAt])
  @@index([status, startedAt])
  @@map("event_source_runs")
}

model EventChangeAlert {
  id                String                 @id @default(cuid())
  eventId           String                 @map("event_id")
  sourceId          String                 @map("source_id")
  sourceRunId       String?                @map("source_run_id")
  sourceCandidateId String?                @map("source_candidate_id")
  status            EventChangeAlertStatus @default(open)
  severity          EventChangeSeverity
  changedFields     String[]               @map("changed_fields")
  beforeValue       Json                   @map("before_value")
  afterValue        Json                   @map("after_value")
  evidence          Json
  sourceUrl         String?                @map("source_url")
  fingerprint       String
  reviewedBy        String?                @map("reviewed_by")
  reviewedAt        DateTime?              @map("reviewed_at")
  reviewNote        String?                @map("review_note")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source          EventSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceRun       EventSourceRun? @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  sourceCandidate EventCandidate? @relation(fields: [sourceCandidateId], references: [id], onDelete: SetNull)

  @@unique([eventId, sourceId, fingerprint])
  @@index([status, severity, createdAt])
  @@index([eventId, status])
  @@map("event_change_alerts")
}

model ShareRecord {
  id             String    @id @default(cuid())
  userKey        String?   @map("user_key")
  userId         String?   @map("user_id")
  userKeyHash    String?   @map("user_key_hash")
  shareToken     String?   @unique @map("share_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  eventId        String?   @map("event_id")
  shareType      String    @map("share_type")
  scene          String
  createdAt      DateTime  @default(now()) @map("created_at")

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userKeyHash])
  @@index([shareToken, tokenExpiresAt])
  @@index([eventId])
  @@index([createdAt])
  @@map("share_records")
}

model EventInteraction {
  id           String                 @id @default(cuid())
  userKeyHash  String                 @map("user_key_hash")
  eventId      String                 @map("event_id")
  action       EventInteractionAction
  occurredDate DateTime               @map("occurred_date") @db.Date
  createdAt    DateTime               @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userKeyHash, eventId, action, occurredDate])
  @@index([eventId, action, occurredDate])
  @@index([action, occurredDate])
  @@map("event_interactions")
}
