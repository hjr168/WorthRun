generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishStatus {
  draft
  published
  hidden
  offline
  archived
}

enum InfoStatus {
  ai_generated
  pending_verify
  verified
  user_flagged
  source_error
}

enum RunJudgement {
  priority
  watch
  unverified
}

enum SignupStatus {
  signup_open
  closing_soon
  closed
  not_started
  unknown
}

enum SourceLevel {
  official
  trusted
  secondary
  unknown
}

enum FeedbackStatus {
  pending
  handling
  resolved
  rejected
}

enum AdminRole {
  super_admin
  event_operator
  content_reviewer
  readonly
}

enum AdminStatus {
  active
  disabled
}

enum EventSourceType {
  page_url
  chinaath_api
  search_query
  rss
}

enum EventSourceStatus {
  active
  paused
}

enum EventCandidateStatus {
  new
  needs_review
  accepted
  rejected
  merged
}

model Event {
  id               String               @id @default(cuid())
  eventName        String               @map("event_name")
  city             String
  eventDate        DateTime             @map("event_date") @db.Date
  distanceItems    String[]             @map("distance_items")
  startPoint       String?              @map("start_point")
  endPoint         String?              @map("end_point")
  signupStatus     SignupStatus         @default(unknown) @map("signup_status")
  signupStartAt    DateTime?            @map("signup_start_at")
  signupDeadline   DateTime?            @map("signup_deadline")
  officialUrl      String               @map("official_url")
  sourceName       String               @map("source_name")
  sourceUrl        String?              @map("source_url")
  sourceLevel      SourceLevel          @default(unknown) @map("source_level")
  publishStatus    PublishStatus        @default(draft) @map("publish_status")
  infoStatus       InfoStatus           @default(pending_verify) @map("info_status")
  runJudgement     RunJudgement         @default(unverified) @map("run_judgement")
  judgementSummary String?              @map("judgement_summary")
  judgementReasons String[]             @default([]) @map("judgement_reasons")
  suitableFor      String[]             @default([]) @map("suitable_for")
  notSuitableFor   String[]             @default([]) @map("not_suitable_for")
  tags             String[]             @default([])
  fieldConfidence  Json?                @map("field_confidence")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  publishedAt      DateTime?            @map("published_at")
  archivedAt       DateTime?            @map("archived_at")

  checklistItems EventChecklistItem[]
  eventTags      EventTag[]
  favorites      UserFavorite[]
  feedback       Feedback[]
  shareRecords   ShareRecord[]

  @@index([city])
  @@index([eventDate])
  @@index([publishStatus])
  @@index([signupStatus])
  @@map("events")
}

model EventChecklistItem {
  id          String     @id @default(cuid())
  eventId     String     @map("event_id")
  groupName   String     @map("group_name")
  itemName    String     @map("item_name")
  itemStatus  InfoStatus @default(pending_verify) @map("item_status")
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_checklist_items")
}

model EventTag {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  tagName   String   @map("tag_name")
  tagType   String   @default("experience") @map("tag_type")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_tags")
}

model UserPreference {
  id        String   @id @default(cuid())
  userKey   String   @unique @map("user_key")
  cities    String[]  @default([])
  distances String[]  @default([])
  focusTags String[]  @default([]) @map("focus_tags")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model UserFavorite {
  id        String   @id @default(cuid())
  userKey   String   @map("user_key")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userKey, eventId])
  @@index([eventId])
  @@map("user_favorites")
}

model Feedback {
  id           String         @id @default(cuid())
  eventId      String?        @map("event_id")
  userKey      String?        @map("user_key")
  feedbackType String         @map("feedback_type")
  content      String
  status       FeedbackStatus @default(pending)
  adminNote    String?        @map("admin_note")
  handledBy    String?        @map("handled_by")
  handledAt    DateTime?      @map("handled_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([eventId])
  @@map("feedback")
}

model AdminUser {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String      @map("password_hash")
  displayName  String      @map("display_name")
  role         AdminRole   @default(event_operator)
  status       AdminStatus @default(active)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  operationLogs AdminOperationLog[]

  @@map("admin_users")
}

model AdminOperationLog {
  id          String   @id @default(cuid())
  adminUserId String?  @map("admin_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_operation_logs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  configValue Json     @map("config_value")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model EventSource {
  id             String            @id @default(cuid())
  name           String
  sourceType     EventSourceType   @default(page_url) @map("source_type")
  entryUrl       String?           @map("entry_url")
  searchQuery    String?           @map("search_query")
  allowedDomains String[]          @default([]) @map("allowed_domains")
  cityHints      String[]          @default([]) @map("city_hints")
  status         EventSourceStatus @default(active)
  lastRunAt      DateTime?         @map("last_run_at")
  lastRunStatus  String?           @map("last_run_status")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  candidates EventCandidate[]

  @@index([status])
  @@map("event_sources")
}

model EventCandidate {
  id               String               @id @default(cuid())
  sourceId         String?              @map("source_id")
  status           EventCandidateStatus @default(new)
  eventName        String               @map("event_name")
  city             String
  eventDate        DateTime?            @map("event_date") @db.Date
  sourceUrl        String?              @map("source_url")
  officialUrl      String?              @map("official_url")
  extractedData    Json                 @map("extracted_data")
  evidence         Json
  confidence       Json?
  duplicateEventId String?              @map("duplicate_event_id")
  acceptedEventId  String?              @map("accepted_event_id")
  aiModel          String?              @map("ai_model")
  aiPromptVersion  String?              @map("ai_prompt_version")
  sourceExternalId String?              @map("source_external_id")
  rawPayload       Json?                @map("raw_payload")
  extractorVersion String?              @map("extractor_version")
  reviewedBy       String?              @map("reviewed_by")
  reviewedAt       DateTime?            @map("reviewed_at")
  rejectReason     String?              @map("reject_reason")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  source EventSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([sourceId, sourceExternalId])
  @@index([status])
  @@index([sourceId])
  @@index([eventName, city, eventDate])
  @@map("event_candidates")
}

model ShareRecord {
  id        String   @id @default(cuid())
  userKey   String?  @map("user_key")
  eventId   String?  @map("event_id")
  shareType String   @map("share_type")
  scene     String
  createdAt DateTime @default(now()) @map("created_at")

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([createdAt])
  @@map("share_records")
}
