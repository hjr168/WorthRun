# 生产环境建议追加 connection_limit=2&pool_timeout=10，降低 API 与短时 cron 并存时的连接内存。
DATABASE_URL="postgresql://worth_running:worth_running@localhost:5432/worth_running?schema=public"
API_PORT=4000
APP_RELEASE="dev"
ADMIN_TOKEN_SECRET="change-me-in-production"
# 外部分享图允许的 HTTPS 主机名，需同时加入微信小程序 downloadFile 合法域名。
SHARE_IMAGE_ALLOWED_HOSTS="run-api.huangjiarong.top"
VITE_API_BASE_URL="http://localhost:4000"
# 小程序码生成（V0.2 分享图）。从微信公众平台「开发管理 → 开发设置」获取。
# 未配置时 /api/wxacode 返回 503，分享图降级为占位提示。
WX_APPID=""
WX_APPSECRET=""

# AI 赛事源抽取。未配置时可保存赛事源，但手动抓取会失败。
# 可选 provider: glm / deepseek / openai
AI_INGEST_PROVIDER="glm"
ZHIPUAI_API_KEY=""
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""
AI_INGEST_MODEL=""
AI_INGEST_BASE_URL=""
AI_INGEST_USER_AGENT="WorthRunBot/0.1 (+contact-url)"

# 可用内存低于该值时，一次性赛事源任务跳过本轮；有效范围 128..512。
EVENT_SOURCE_MIN_AVAILABLE_MB=256
