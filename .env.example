# 生产环境建议追加 connection_limit=2&pool_timeout=10，降低 API 与短时 cron 并存时的连接内存。
DATABASE_URL="postgresql://worth_running:worth_running@localhost:5432/worth_running?schema=public"
API_PORT=4000
APP_RELEASE="dev"
ADMIN_TOKEN_SECRET="change-me-in-production"
# 外部分享图允许的 HTTPS 主机名，需同时加入微信小程序 downloadFile 合法域名。
SHARE_IMAGE_ALLOWED_HOSTS="run-api.huangjiarong.top"
VITE_API_BASE_URL="http://localhost:4000"
# 小程序码生成（V0.2 分享图）。从微信公众平台「开发管理 → 开发设置」获取。
# 未配置时 /api/wxacode 返回 503，分享图降级为占位提示。
WX_APPID=""
WX_APPSECRET=""

# V0.5.3 微信用户体系。外部依赖部署完成前保持 false。
USER_SYSTEM_ENABLED="false"
REMINDER_FEATURE_ENABLED="false"
USER_TOKEN_SECRET=""
USER_OPENID_HASH_SECRET=""
# openssl rand -base64 32
USER_OPENID_ENCRYPTION_KEY=""
WX_SIGNUP_REMINDER_TEMPLATE_ID="D-aGSBJK_2IqO3K4jed09QWQVa3_TSn3UpRLLRELRDw"
WX_RACE_REMINDER_TEMPLATE_ID="PBITIMZTOYtJz2GyeBsETjPIUbraWRQ4RGZjm3GJLDM"
# 订阅消息模板字段键必须按微信公众平台所选模板填写，例如 thing1 / thing2 / time3。
WX_SIGNUP_REMINDER_EVENT_FIELD="thing9"
WX_SIGNUP_REMINDER_NOTICE_FIELD="thing3"
WX_SIGNUP_REMINDER_DATE_FIELD="time2"
WX_RACE_REMINDER_EVENT_FIELD="thing1"
WX_RACE_REMINDER_NOTICE_FIELD="thing5"
WX_RACE_REMINDER_DATE_FIELD="time11"
WX_MINIPROGRAM_STATE="formal"

# UniCloud 支付宝云 URL 化头像函数，与云函数 AVATAR_SHARED_SECRET 一致。
UNICLOUD_AVATAR_BASE_URL="https://env-00jy6bpz3vhc.dev-hz.cloudbasefunction.cn/worthrun-avatar"
UNICLOUD_AVATAR_SHARED_SECRET=""
UNICLOUD_SPACE_ID="env-00jy6bpz3vhc"
UNICLOUD_PROVIDER="alipay"
UNICLOUD_SPACE_EXPIRES_AT="2026-08-26T23:59:59+08:00"

# AI 赛事源抽取。未配置时可保存赛事源，但手动抓取会失败。
# 可选 provider: glm / deepseek / openai
AI_INGEST_PROVIDER="glm"
ZHIPUAI_API_KEY=""
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""
AI_INGEST_MODEL=""
AI_INGEST_BASE_URL=""
AI_INGEST_USER_AGENT="WorthRunBot/0.1 (+contact-url)"

# 可用内存低于该值时，一次性赛事源任务跳过本轮；有效范围 128..512。
EVENT_SOURCE_MIN_AVAILABLE_MB=256
